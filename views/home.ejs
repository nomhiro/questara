<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-4xl px-5 py-8 sm:px-8">
  <header class="mb-8 rise">
    <h1 class="text-2xl font-semibold tracking-tight">ようこそ、<%= userName %> さん</h1>
    <p class="mt-1 text-sm text-ink-2">今日も一歩、合格へ。</p>
  </header>

  <%
    const lv = (heroStats && heroStats.level) || 1;
    const xpInto = (heroStats && heroStats.xpIntoLevel) || 0;
    const xpFor = (heroStats && heroStats.xpForLevel) || 100;
    const xpPct = Math.min(100, Math.round((xpInto / xpFor) * 100));
    const streak = (heroStats && heroStats.streak && heroStats.streak.current) || 0;
    const achv = (heroStats && (heroStats.unlockedAchievements || []).length) || 0;
  %>
  <section class="card mb-8 rise" style="animation-delay:.04s">
    <div class="flex flex-wrap items-center gap-x-8 gap-y-4">
      <div>
        <div class="text-xs text-ink-3">レベル</div>
        <div class="mt-0.5 flex items-baseline gap-1"><span class="text-sm text-ink-3">Lv.</span><span class="nums text-2xl font-semibold"><%= lv %></span></div>
      </div>
      <div class="min-w-[180px] flex-1">
        <div class="mb-1.5 flex items-center justify-between text-xs text-ink-3"><span>EXP</span><span class="nums"><%= xpInto %> / <%= xpFor %></span></div>
        <span class="progress block"><i style="width:<%= xpPct %>%"></i></span>
      </div>
      <div>
        <div class="text-xs text-ink-3">連続学習</div>
        <div class="mt-0.5"><span aria-hidden="true">🔥</span> <span class="nums text-lg font-semibold"><%= streak %></span><span class="text-sm text-ink-2">日</span></div>
      </div>
      <div>
        <div class="text-xs text-ink-3">実績</div>
        <div class="mt-0.5"><span aria-hidden="true">🏅</span> <span class="nums text-lg font-semibold"><%= achv %></span></div>
      </div>
      <a href="/my/profile" class="btn btn-subtle btn-sm ml-auto">ステータス詳細</a>
    </div>
  </section>

  <section class="mb-8">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-lg font-semibold tracking-tight">学習中の資格</h2>
      <a href="/certifications" class="btn btn-primary btn-sm">資格をさがす</a>
    </div>
    <% if (learningCerts.length === 0) { %>
      <div class="card text-center text-ink-2">
        <p>まだ学習中の資格がありません。</p>
        <a href="/certifications" class="mt-3 inline-block font-medium text-accent">資格をさがして ☆ で登録する →</a>
      </div>
    <% } else { %>
      <div class="grid gap-3">
        <% for (const c of learningCerts) { %>
          <a href="/certifications/<%= c.id %>" class="card card-hover flex items-center justify-between gap-4">
            <div class="min-w-0">
              <h3 class="flex items-center gap-2 font-medium">
                <span class="truncate"><%= c.name %></span>
                <% if (c.passed) { %><span class="badge badge-success shrink-0">🎓 合格</span><% } %>
              </h3>
              <p class="mt-1 text-sm text-ink-2">
                <span class="nums"><%= c.domainCount %></span> ドメイン · <span class="nums"><%= c.questionCount %></span> 問
                <% if (c.correctRate !== null && c.correctRate !== undefined) { %>
                  · 正答率 <span class="nums font-medium <%= c.correctRate >= 70 ? 'text-success' : 'text-ink' %>"><%= c.correctRate %>%</span>
                <% } else { %>
                  · <span class="text-ink-3">未挑戦</span>
                <% } %>
              </p>
            </div>
            <span class="btn btn-subtle btn-sm shrink-0">続ける →</span>
          </a>
        <% } %>
      </div>
    <% } %>
  </section>

  <section>
    <h2 class="mb-3 text-lg font-semibold tracking-tight">メニュー</h2>
    <div class="grid gap-3 sm:grid-cols-3">
      <a href="/certifications" class="card card-hover">
        <h3 class="font-medium">資格をさがす</h3>
        <p class="mt-1 text-sm text-ink-2">学習中・公開・自作の全資格。</p>
      </a>
      <a href="/ranking" class="card card-hover">
        <h3 class="font-medium">ランキング</h3>
        <p class="mt-1 text-sm text-ink-2">みんなの正答率ランキング。</p>
      </a>
      <a href="/plans" class="card card-hover">
        <h3 class="font-medium">学習計画</h3>
        <p class="mt-1 text-sm text-ink-2">目標日に向けた学習プラン。</p>
      </a>
    </div>
  </section>
</main>
<%- include('partials/foot') %>
