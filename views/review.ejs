<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-3xl px-5 py-8 sm:px-8">
  <nav class="mb-4 flex items-center gap-2 text-sm text-ink-3" aria-label="パンくず">
    <a href="/home" class="text-ink-2 hover:text-ink">ホーム</a>
    <span aria-hidden="true">/</span>
    <a href="/certifications/<%= certId %>" class="text-ink-2 hover:text-ink"><%= certId.toUpperCase() %></a>
    <span aria-hidden="true">/</span>
    <span class="text-ink">間違い復習</span>
  </nav>

  <h1 class="text-xl font-semibold tracking-tight">間違えた問題の復習</h1>
  <p class="mb-6 mt-2 text-sm text-ink-2"><span class="badge badge-danger">✗ <span class="nums"><%= wrongQuestions.length %></span> 問</span> を間違えました</p>

  <% if (wrongQuestions.length === 0) { %>
    <section class="card text-center">
      <div class="mb-2 text-4xl">🎉</div>
      <p class="font-medium text-success">このセッションでは間違えた問題はありませんでした！</p>
    </section>
  <% } %>

  <div class="flex flex-col gap-4">
    <% for (let i = 0; i < wrongQuestions.length; i++) { %>
      <% const q = wrongQuestions[i]; %>
      <section class="card">
        <span class="badge badge-danger mb-3"><%= q.domainName %></span>
        <p class="mb-4 leading-relaxed">Q<%= i + 1 %>. <%= q.question %></p>
        <div class="mb-4 flex flex-col gap-2">
          <% for (const [key, val] of Object.entries(q.options)) { %>
            <% const answerKeys = (Array.isArray(q.correctAnswers) && q.correctAnswers.length > 0) ? q.correctAnswers : [q.correctAnswer]; %>
            <% const pickedKeys = String(q.selectedAnswer || '').split(','); %>
            <% const isCorrect = answerKeys.includes(key); %>
            <% const isPicked = pickedKeys.includes(key); %>
            <% const cls = isCorrect ? 'border-success bg-success-soft text-success' : (isPicked ? 'border-danger bg-danger-soft text-danger' : 'border-line text-ink-2'); %>
            <div class="flex items-start gap-2.5 rounded-lg border px-3 py-2 text-sm <%= cls %>">
              <span class="font-mono font-semibold"><%= key %>.</span>
              <span class="flex-1"><%= val %></span>
              <% if (isCorrect) { %><span class="shrink-0 text-xs">✓ 正解</span>
              <% } else if (isPicked) { %><span class="shrink-0 text-xs">← あなたの回答</span><% } %>
            </div>
          <% } %>
        </div>
        <div class="border-t border-line pt-3 text-sm leading-relaxed text-ink-2">
          <span class="font-medium text-ink">解説:</span> <%= q.explanation %>
        </div>

        <div class="ask-ai mt-3">
          <button type="button" class="btn btn-subtle"
            onclick="askAi(this, '<%= certId %>', '<%= q.domainId %>', '<%= q.id %>')">
            🔍 AIに詳しく聞く
          </button>
          <div class="ask-ai-result mt-3 hidden rounded-lg border border-line p-4 text-sm leading-relaxed"></div>
        </div>
      </section>
    <% } %>
  </div>

  <div class="mt-7 flex flex-wrap gap-2">
    <form method="POST" action="/quiz/start" class="m-0">
      <input type="hidden" name="certId" value="<%= certId %>">
      <input type="hidden" name="mode" value="wrong-only">
      <button class="btn btn-subtle" type="submit">間違えた問題で再挑戦</button>
    </form>
    <a href="/certifications/<%= certId %>" class="btn btn-primary">← 資格ページへ</a>
  </div>
</main>
<%- include('partials/ask-ai') %>
<%- include('partials/foot') %>
