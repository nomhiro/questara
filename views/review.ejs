<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

  <main class="main">

    <div style="font-family: var(--font-body); font-size: 12px; color: #c0c6e0; margin-bottom: 8px;">
      <a href="/" style="color: var(--gold); text-decoration:none;">🏰 ホーム</a>
      <span style="opacity:.6; margin: 0 6px;">▸</span>
      <a href="/certifications/<%= certId %>" style="color: var(--gold); text-decoration:none;"><%= certId.toUpperCase() %></a>
      <span style="opacity:.6; margin: 0 6px;">▸</span>
      <span>間違い復習</span>
    </div>

    <h1 class="rpg-title" style="font-size: 24px; margin-bottom: 4px;">📜 間違えた問題の復習</h1>
    <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 13px; margin-bottom: 24px;">
      <span class="pill" style="color: var(--crimson);">✗ <%= wrongQuestions.length %> 問</span> を間違えました
    </p>

    <% if (wrongQuestions.length === 0) { %>
      <section class="rpg-window is-open" style="text-align:center;">
        <div style="font-size: 40px; margin-bottom: 8px;">🎉</div>
        <p style="font-family: var(--font-display); color: var(--fern); font-size: 16px; text-shadow: 2px 2px 0 var(--shadow); margin: 0;">
          このセッションでは間違えた問題はありませんでした！
        </p>
      </section>
    <% } %>

    <div style="display:flex; flex-direction:column; gap: 18px;">
      <% for (let i = 0; i < wrongQuestions.length; i++) { %>
        <% const q = wrongQuestions[i]; %>
        <section class="rpg-window is-open" style="border-color: var(--crimson); box-shadow: inset 0 0 0 3px var(--window), inset 0 0 0 6px #7a1320, 4px 4px 0 var(--shadow);">
          <div class="pill" style="color: var(--crimson); border-color: var(--crimson); margin-bottom: 10px;">
            <%= q.domainName %>
          </div>
          <p style="font-family: var(--font-body); font-size: 15px; line-height: 1.7; color: var(--ink); margin: 0 0 16px;">
            Q<%= i + 1 %>. <%= q.question %>
          </p>

          <div style="display:flex; flex-direction:column; gap: 8px; margin-bottom: 16px;">
            <% for (const [key, val] of Object.entries(q.options)) { %>
              <% const answerKeys = (Array.isArray(q.correctAnswers) && q.correctAnswers.length > 0) ? q.correctAnswers : [q.correctAnswer]; %>
              <% const pickedKeys = String(q.selectedAnswer || '').split(','); %>
              <% const isCorrect = answerKeys.includes(key); %>
              <% const isPicked = pickedKeys.includes(key); %>
              <% const bg = isCorrect ? '#1f4a18' : (isPicked ? '#3a0a12' : '#000a'); %>
              <% const border = isCorrect ? 'var(--fern)' : (isPicked ? 'var(--crimson)' : 'var(--ink)'); %>
              <% const color = isCorrect ? 'var(--fern)' : (isPicked ? 'var(--crimson)' : 'var(--ink)'); %>
              <div style="display:flex; gap: 10px; align-items:flex-start; padding: 8px 12px; background: <%= bg %>; border: 2px solid <%= border %>; font-family: var(--font-body); font-size: 13px; color: <%= color %>;">
                <span style="font-family: var(--font-display); font-weight: bold; flex-shrink:0; color: var(--gold);"><%= key %>.</span>
                <span style="flex:1;"><%= val %></span>
                <% if (isCorrect) { %>
                  <span style="font-family: var(--font-display); font-size: 11px;">✓ 正解</span>
                <% } else if (isPicked) { %>
                  <span style="font-family: var(--font-display); font-size: 11px;">← あなたの回答</span>
                <% } %>
              </div>
            <% } %>
          </div>

          <div style="padding-top: 12px; border-top: 2px dashed var(--gold); font-family: var(--font-body); font-size: 13px; line-height: 1.7; color: #dadde6;">
            <span style="font-family: var(--font-display); color: var(--gold); margin-right: 6px;">📖 解説:</span>
            <%= q.explanation %>
          </div>
        </section>
      <% } %>
    </div>

    <div style="margin-top: 28px; display:flex; flex-wrap:wrap; gap: 12px;">
      <form method="POST" action="/quiz/start" style="margin:0;">
        <input type="hidden" name="certId" value="<%= certId %>">
        <input type="hidden" name="mode" value="wrong-only">
        <button class="rpg-btn" type="submit">❌ 間違えた問題で再挑戦</button>
      </form>
      <a href="/certifications/<%= certId %>" class="rpg-btn is-gold">← 資格ページへ</a>
    </div>

  </main>
</body>
</html>
