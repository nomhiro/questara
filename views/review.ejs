<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-gray-900 text-white px-6 py-3 flex items-center gap-2 text-sm">
    <a href="/" class="font-bold">📚</a>
    <span class="text-gray-400">/</span>
    <a href="/certifications/<%= certId %>" class="text-gray-300 hover:text-white"><%= certId.toUpperCase() %></a>
    <span class="text-gray-400">/</span>
    <span class="text-gray-200">間違い復習</span>
  </nav>
  <main class="max-w-3xl mx-auto px-4 py-8">

    <h1 class="text-2xl font-bold mb-2">間違えた問題の復習</h1>
    <p class="text-gray-500 mb-8"><%= wrongQuestions.length %> 問を間違えました</p>

    <% if (wrongQuestions.length === 0) { %>
      <div class="bg-green-50 border border-green-200 rounded-xl p-6 text-center text-green-700">
        🎉 このセッションでは間違えた問題はありませんでした！
      </div>
    <% } %>

    <div class="space-y-6">
      <% for (let i = 0; i < wrongQuestions.length; i++) { %>
        <% const q = wrongQuestions[i]; %>
        <div class="bg-white border border-red-200 rounded-2xl p-6">
          <div class="text-xs font-medium text-red-500 mb-2"><%= q.domainName %></div>
          <p class="font-medium text-gray-800 mb-4 leading-relaxed"><%= q.question %></p>

          <div class="space-y-2 mb-4">
            <% for (const [key, val] of Object.entries(q.options)) { %>
              <div class="flex gap-2 items-start text-sm rounded-lg px-3 py-2
                <%= key === q.correctAnswer ? 'bg-green-50 text-green-800 font-medium' :
                    key === q.selectedAnswer ? 'bg-red-50 text-red-700' : 'text-gray-600' %>">
                <span class="font-bold flex-shrink-0"><%= key %>.</span>
                <span>
                  <%= val %>
                  <% if (key === q.correctAnswer) { %> <span class="ml-1">✓ 正解</span><% } %>
                  <% if (key === q.selectedAnswer && key !== q.correctAnswer) { %> <span class="ml-1">← あなたの回答</span><% } %>
                </span>
              </div>
            <% } %>
          </div>

          <div class="pt-3 border-t border-gray-100 text-sm text-gray-600 leading-relaxed">
            <span class="font-medium text-gray-700">解説:</span> <%= q.explanation %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <form method="POST" action="/quiz/start">
        <input type="hidden" name="certId" value="<%= certId %>">
        <input type="hidden" name="mode" value="wrong-only">
        <button class="bg-red-500 hover:bg-red-600 text-white font-semibold px-5 py-2 rounded-lg text-sm">
          ❌ 間違えた問題で再挑戦
        </button>
      </form>
      <a href="/certifications/<%= certId %>"
         class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-5 py-2 rounded-lg text-sm inline-block">
        ← 資格ページへ
      </a>
    </div>

  </main>
</body>
</html>
