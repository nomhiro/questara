<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Questara — 資格学習エージェント</title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    /* ======================================================
       1. 背景の霧
    ====================================================== */
    .hero-fog {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background: radial-gradient(ellipse 70% 60% at 50% 50%,
        rgba(180,160,80,0.18) 0%,
        rgba(80,60,120,0.12) 50%,
        transparent 100%);
      opacity: 0.25;
      animation: fog-slide 20s ease-in-out infinite alternate;
    }
    @keyframes fog-slide {
      from { transform: translateX(-12%) scaleX(1.1); }
      to   { transform: translateX(12%)  scaleX(0.95); }
    }

    /* ======================================================
       2. タイトル ⚔ の揺らぎ
    ====================================================== */
    .flame-flicker {
      display: inline-block;
      animation: flicker 1.5s ease-in-out infinite alternate;
    }
    @keyframes flicker {
      from { transform: rotate(-3deg) scale(0.95); }
      to   { transform: rotate(3deg)  scale(1.05); }
    }

    /* ======================================================
       3. Questara 文字 glow
    ====================================================== */
    .title-glow {
      animation: glow 3s ease-in-out infinite alternate;
    }
    @keyframes glow {
      from {
        text-shadow:
          0 0  6px rgba(212,175,55,0.4),
          0 0 12px rgba(212,175,55,0.3),
          0 0 24px rgba(212,175,55,0.1);
      }
      to {
        text-shadow:
          0 0 10px rgba(212,175,55,0.9),
          0 0 22px rgba(212,175,55,0.7),
          0 0 40px rgba(212,175,55,0.35),
          0 0 60px rgba(180,80,80,0.15);
      }
    }

    /* ======================================================
       5. 足元スライム
    ====================================================== */
    .slime {
      display: inline-block;
      animation: slime-bounce 1.2s ease-in-out infinite;
    }
    @keyframes slime-bounce {
      0%   { transform: translateY(0)   rotate(0deg); }
      40%  { transform: translateY(-8px) rotate(-2deg); }
      60%  { transform: translateY(-8px) rotate(2deg); }
      100% { transform: translateY(0)   rotate(0deg); }
    }

    /* ======================================================
       6. 松明
    ====================================================== */
    .torch {
      position: absolute;
      top: -10px;
      z-index: 1;
      pointer-events: none;
    }
    .torch-left { left: 16px; }
    .torch-right { right: 16px; }
    .torch-flame {
      transform-origin: 16px 35px;
      animation: torch-flicker 0.3s ease-in-out infinite alternate;
    }
    @keyframes torch-flicker {
      from { transform: scale(1) skewX(-2deg); filter: brightness(1); }
      to { transform: scale(1.05, 1.1) skewX(2deg); filter: brightness(1.15); }
    }

    /* ======================================================
       7. コウモリ
    ====================================================== */
    .bat {
      position: absolute;
      top: 30px;
      z-index: 1;
      pointer-events: none;
      opacity: 0.85;
    }
    .bat-1 {
      left: 15%;
      animation: bat-fly-1 5s ease-in-out infinite alternate;
    }
    .bat-2 {
      right: 15%;
      animation: bat-fly-2 6s ease-in-out infinite alternate;
    }
    @keyframes bat-fly-1 {
      0% { transform: translate(0, 0) scaleX(1); }
      50% { transform: translate(40px, 15px) scaleX(-1); }
      100% { transform: translate(10px, -10px) scaleX(1); }
    }
    @keyframes bat-fly-2 {
      0% { transform: translate(0, 0) scaleX(1); }
      50% { transform: translate(-30px, 20px) scaleX(-1); }
      100% { transform: translate(-10px, -12px) scaleX(1); }
    }

    /* ======================================================
       8. 剣士 & キャラクター対面構図
    ====================================================== */
    .knight-sword {
      transform-origin: 45.5px 41px;
      animation: sword-swing 2.5s ease-in-out infinite;
    }
    @keyframes sword-swing {
      0%, 100% { transform: rotate(0deg); }
      45% { transform: rotate(-45deg); }
      55% { transform: rotate(-45deg); }
    }
    .character-pair {
      display: flex;
      justify-content: center;
      gap: 40px;
      align-items: flex-end;
      margin: 24px 0 8px;
    }

    /* ======================================================
       9. Scroll フェードイン
    ====================================================== */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .reveal.revealed {
      opacity: 1;
      transform: none;
    }

    /* ======================================================
       7. CTA 魔法陣
    ====================================================== */
    .magic-circle-wrap {
      position: relative;
      display: inline-block;
    }
    .magic-circle {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 240px;
      height: 240px;
      transform: translate(-50%, -50%);
      opacity: 0.15;
      z-index: 0;
      pointer-events: none;
      animation: spin 30s linear infinite;
    }
    @keyframes spin {
      from { transform: translate(-50%, -50%) rotate(0deg); }
      to   { transform: translate(-50%, -50%) rotate(360deg); }
    }
    .magic-circle-wrap:hover .magic-circle {
      opacity: 0.35;
    }
    .magic-circle-wrap .rpg-btn {
      position: relative;
      z-index: 2;
    }

    /* ======================================================
       8. prefers-reduced-motion
    ====================================================== */
    @media (prefers-reduced-motion: reduce) {
      .hero-fog,
      .flame-flicker,
      .title-glow,
      .slime,
      .reveal,
      .magic-circle,
      .torch-flame,
      .bat,
      .bat-1,
      .bat-2,
      .knight-sword {
        animation: none !important;
        transform: none !important;
        transition: none !important;
      }
      .reveal {
        opacity: 1 !important;
      }
    }
  </style>
</head>
<body>
  <nav class="hud">
    <div class="hud-cell">📚 <span class="value">Questara</span></div>
    <div class="hud-spacer"></div>
    <% if (userEmail) { %>
      <span class="hud-cell" style="font-size:11px;"><%= userEmail %></span>
      <form method="POST" action="/auth/logout" style="margin:0;"><button type="submit" class="rpg-btn" style="font-size:11px;padding:6px 12px;">ログアウト</button></form>
    <% } %>
  </nav>

  <main class="main" style="max-width: 960px; margin: 0 auto;">

    <% if (errorMessage) { %>
      <section class="rpg-window is-open" style="background: #3a0a12; border-color: var(--crimson); margin-bottom: 24px;">
        <p style="color: var(--ink); font-family: var(--font-body); font-size: 13px; margin:0;">⚠ <%= errorMessage %></p>
      </section>
    <% } %>

    <!-- Hero -->
    <section class="rpg-window is-open reveal" style="text-align:center; padding: 40px 24px; margin-bottom: 32px; position:relative; overflow:hidden;">
      <!-- 1. 背景の霧 -->
      <div class="hero-fog"></div>
      <!-- 3-a. 松明2本 -->
      <span class="torch torch-left" aria-hidden="true">
        <svg viewBox="0 0 32 80" width="32" height="80">
          <rect x="13" y="35" width="6" height="40" fill="#5b3a20" stroke="#2d1c0f" stroke-width="1"/>
          <rect x="11" y="33" width="10" height="5" fill="#7a4e2b"/>
          <g class="torch-flame">
            <path d="M16 8 Q10 20 12 30 Q14 35 16 35 Q18 35 20 30 Q22 20 16 8 Z" fill="#ff9833"/>
            <path d="M16 14 Q12 22 14 30 Q16 33 16 33 Q16 33 18 30 Q20 22 16 14 Z" fill="#ffde59"/>
            <circle cx="16" cy="26" r="2" fill="#fff" opacity="0.8"/>
          </g>
        </svg>
      </span>
      <span class="torch torch-right" aria-hidden="true">
        <svg viewBox="0 0 32 80" width="32" height="80">
          <rect x="13" y="35" width="6" height="40" fill="#5b3a20" stroke="#2d1c0f" stroke-width="1"/>
          <rect x="11" y="33" width="10" height="5" fill="#7a4e2b"/>
          <g class="torch-flame">
            <path d="M16 8 Q10 20 12 30 Q14 35 16 35 Q18 35 20 30 Q22 20 16 8 Z" fill="#ff9833"/>
            <path d="M16 14 Q12 22 14 30 Q16 33 16 33 Q16 33 18 30 Q20 22 16 14 Z" fill="#ffde59"/>
            <circle cx="16" cy="26" r="2" fill="#fff" opacity="0.8"/>
          </g>
        </svg>
      </span>
      <!-- 3-b. コウモリ2匹 -->
      <span class="bat bat-1" aria-hidden="true">
        <svg viewBox="0 0 32 20" width="32" height="20">
          <path d="M16 10 L11 7 L4 10 L8 6 L2 4 L10 4 L16 8 L22 4 L30 4 L24 6 L28 10 L21 7 Z" fill="#1a1a2a"/>
          <circle cx="15" cy="9" r="1" fill="#ff3355"/>
          <circle cx="17" cy="9" r="1" fill="#ff3355"/>
        </svg>
      </span>
      <span class="bat bat-2" aria-hidden="true">
        <svg viewBox="0 0 32 20" width="32" height="20">
          <path d="M16 10 L11 7 L4 10 L8 6 L2 4 L10 4 L16 8 L22 4 L30 4 L24 6 L28 10 L21 7 Z" fill="#1a1a2a"/>
          <circle cx="15" cy="9" r="1" fill="#ff3355"/>
          <circle cx="17" cy="9" r="1" fill="#ff3355"/>
        </svg>
      </span>
      <!-- コンテンツ（z-index:1 で霧の上） -->
      <div style="position:relative; z-index:1;">
        <!-- 2. タイトル ⚔ glow + flicker -->
        <h1 class="rpg-title title-glow" style="font-size: 36px; margin-bottom: 4px; letter-spacing: 0.08em;">
          <span class="flame-flicker">⚔</span> Questara <span class="flame-flicker">⚔</span>
        </h1>
        <p style="font-family: var(--font-body); color: var(--gold); font-size: 14px; margin: 0 0 28px; letter-spacing: 0.2em;">— クエスターラ —</p>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 13px; line-height: 1.8; margin: 0 0 20px; max-width: 560px; margin-left:auto; margin-right:auto;">
          Microsoft / GitHub 認定資格の学習を、<br>
          クエストを解いてレベルアップしながら楽しむ学習エージェント。
        </p>
        <!-- スライム vs 剣士 対面構図 -->
        <div class="character-pair">
          <span class="slime" aria-hidden="true">
            <svg viewBox="0 0 64 64" width="72" height="72">
              <defs>
                <radialGradient id="slimeBody" cx="50%" cy="30%" r="70%">
                  <stop offset="0%" stop-color="#b6ecc0" />
                  <stop offset="60%" stop-color="#4fa962" />
                  <stop offset="100%" stop-color="#245c32" />
                </radialGradient>
              </defs>
              <ellipse cx="32" cy="60" rx="18" ry="2.5" fill="#000" opacity="0.25" />
              <path d="M32 8 Q10 28 12 50 Q14 60 32 60 Q50 60 52 50 Q54 28 32 8 Z" fill="url(#slimeBody)" stroke="#1a4022" stroke-width="1.5" />
              <ellipse cx="22" cy="22" rx="4.5" ry="7" fill="white" opacity="0.55" transform="rotate(-15 22 22)" />
              <ellipse cx="24" cy="40" rx="4.5" ry="5.5" fill="white" />
              <ellipse cx="40" cy="40" rx="4.5" ry="5.5" fill="white" />
              <circle cx="25" cy="41" r="2.3" fill="#111" />
              <circle cx="41" cy="41" r="2.3" fill="#111" />
              <circle cx="25.8" cy="40" r="0.9" fill="white" />
              <circle cx="41.8" cy="40" r="0.9" fill="white" />
              <path d="M25 49 Q32 54 39 49" stroke="#111" stroke-width="1.8" fill="none" stroke-linecap="round" />
            </svg>
          </span>
          <span class="hero-knight" aria-hidden="true">
            <svg viewBox="0 0 64 72" width="72" height="80">
              <rect x="24" y="8" width="16" height="14" fill="#d9b47a" stroke="#5a3e1f" stroke-width="1.2"/>
              <rect x="22" y="4" width="20" height="6" fill="#b08e5a" stroke="#5a3e1f" stroke-width="1.2"/>
              <rect x="28" y="14" width="3" height="4" fill="#2a2a3a"/>
              <rect x="33" y="14" width="3" height="4" fill="#2a2a3a"/>
              <rect x="20" y="24" width="24" height="24" fill="#4a6b9a" stroke="#1a2e52" stroke-width="1.2"/>
              <rect x="24" y="30" width="4" height="4" fill="#c0c6e0"/>
              <rect x="36" y="30" width="4" height="4" fill="#c0c6e0"/>
              <rect x="22" y="48" width="8" height="18" fill="#355080" stroke="#1a2e52" stroke-width="1.2"/>
              <rect x="34" y="48" width="8" height="18" fill="#355080" stroke="#1a2e52" stroke-width="1.2"/>
              <g class="knight-sword">
                <rect x="44" y="18" width="3" height="24" fill="#d9d9d9" stroke="#4a4a4a" stroke-width="0.8"/>
                <rect x="41" y="38" width="9" height="3" fill="#8a6a3a"/>
                <rect x="44" y="41" width="3" height="5" fill="#5a3e1f"/>
              </g>
            </svg>
          </span>
        </div>
        <!-- Hero CTA 魔法陣 -->
        <div class="magic-circle-wrap">
          <!-- 魔法陣 SVG (円 + 六芒星) -->
          <svg class="magic-circle" viewBox="0 0 240 240" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="120" cy="120" r="115" stroke="var(--gold)" stroke-width="1.2" stroke-dasharray="6 4"/>
            <circle cx="120" cy="120" r="90"  stroke="var(--gold)" stroke-width="0.8" stroke-dasharray="3 5"/>
            <circle cx="120" cy="120" r="60"  stroke="var(--gold)" stroke-width="0.6"/>
            <!-- 六芒星 (2つの三角形) -->
            <polygon points="120,14 210,167 30,167"   stroke="var(--gold)" stroke-width="1" fill="none"/>
            <polygon points="120,226 30,73  210,73"   stroke="var(--gold)" stroke-width="1" fill="none"/>
            <!-- 中心点 -->
            <circle cx="120" cy="120" r="4" fill="var(--gold)" opacity="0.6"/>
          </svg>
          <!-- CTA ボタン -->
          <% if (userEmail) { %>
            <a href="/my/certifications" class="rpg-btn is-gold" style="display:inline-block; font-size: 14px; padding: 12px 28px;">▶ 学習を再開する</a>
          <% } else { %>
            <a href="/auth/github" class="rpg-btn is-gold" style="display:inline-flex; align-items:center; gap:10px; font-size: 14px; padding: 12px 28px;">
              <svg style="width:18px; height:18px;" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
              GitHubでログインして始める
            </a>
          <% } %>
        </div>
        <p style="font-family: var(--font-body); color: #8a90aa; font-size: 11px; margin: 16px 0 0;">※ ログインと問題生成で GitHub Models API の rate limit を消費します</p>
      </div>
    </section>

    <!-- Why -->
    <h2 class="rpg-title" style="font-size: 18px; margin-bottom: 16px;">✧ このサービスの思い</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 16px;">
      <div class="rpg-window reveal">
        <h3 class="rpg-title" style="font-size: 14px; margin-bottom: 8px;">🗡 ゲームのように学ぶ</h3>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.7; margin: 0;">問題を解くほどレベルアップ＆ランクアップ。単なる暗記ではなく、ゲーム感覚で合格ラインを目指す。</p>
      </div>
      <div class="rpg-window reveal">
        <h3 class="rpg-title" style="font-size: 14px; margin-bottom: 8px;">✨ AIで無限に問題生成</h3>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.7; margin: 0;">Microsoft Learn の学習ガイドを元に AI が実務的な4択問題を生成。飽きずに何度でも挑める。</p>
      </div>
      <div class="rpg-window reveal">
        <h3 class="rpg-title" style="font-size: 14px; margin-bottom: 8px;">📊 弱点を自動ドリル</h3>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.7; margin: 0;">正答率 70% 未満のドメインをワンクリックで再練習。苦手を可視化して潰す。</p>
      </div>
    </div>
    <p style="font-family: var(--font-body); color: var(--gold); font-size: 13px; text-align:center; margin: 0 0 32px;">— みんなで資格取得を通して、学びを楽しめるように —</p>

    <!-- 3ステップで始める -->
    <h2 class="rpg-title" style="font-size: 18px; margin-bottom: 16px;">✧ 3ステップで始める</h2>
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-bottom: 32px;">
      <div class="rpg-window reveal">
        <h3 class="rpg-title" style="font-size: 14px; margin-bottom: 8px;">🔑 1. GitHubでログイン</h3>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.7; margin: 0;">認証と問題生成 API の設定を自動で済ませます。</p>
      </div>
      <div class="rpg-window reveal">
        <h3 class="rpg-title" style="font-size: 14px; margin-bottom: 8px;">📚 2. 資格を選ぶ</h3>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.7; margin: 0;">GH-100・AI-102 など公開資格から選択、または独自資格を追加。</p>
      </div>
      <div class="rpg-window reveal">
        <h3 class="rpg-title" style="font-size: 14px; margin-bottom: 8px;">⚔ 3. クイズに挑戦</h3>
        <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.7; margin: 0;">問題を解いてレベルアップ。弱点を潰して合格ラインへ。</p>
      </div>
    </div>

    <!-- 仕組み（透明性） -->
    <h2 class="rpg-title" style="font-size: 18px; margin-bottom: 16px;">✧ 仕組みと API 利用について</h2>
    <div class="rpg-window reveal" style="margin-bottom: 32px;">
      <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 13px; line-height: 1.8; margin: 0 0 12px;">
        本サービスは問題生成に <strong style="color: var(--gold);">GitHub Models API</strong>(既定モデル: <code>gpt-4o-mini</code>)を使います。
        GitHub アカウントでログインするとご自身のアクセストークンが API 呼び出しに使われ、
        お使いの GitHub Copilot プランに紐づく <strong style="color: var(--gold);">rate limit(1分 / 1日あたりのリクエスト数)</strong>を消費します。
      </p>
      <p style="font-family: var(--font-body); color: #c0c6e0; font-size: 13px; line-height: 1.8; margin: 0 0 12px;">
        問題生成1回 = LLM呼び出し1回です。無料プランでも試せますが、頻繁に問題を再生成するとプラン上限に達することがあります。
      </p>
      <ul style="font-family: var(--font-body); color: #c0c6e0; font-size: 12px; line-height: 1.8; margin: 0; padding-left: 20px;">
        <li>プラン別のレート制限一覧: <a href="https://docs.github.com/en/github-models" target="_blank" rel="noopener" style="color: var(--gold);">GitHub Models ドキュメント</a></li>
        <li>Copilot プランの比較: <a href="https://github.com/features/copilot/plans" target="_blank" rel="noopener" style="color: var(--gold);">GitHub Copilot plans &amp; pricing</a></li>
      </ul>
    </div>

  </main>

  <!-- 6. Scroll フェードイン: IntersectionObserver -->
  <script>
    (function () {
      if (!('IntersectionObserver' in window)) {
        // フォールバック: アニメーション非対応ブラウザは全表示
        document.querySelectorAll('.reveal').forEach(function (el) {
          el.classList.add('revealed');
        });
        return;
      }
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.reveal').forEach(function (el) {
        observer.observe(el);
      });
    })();
  </script>
</body>
</html>
