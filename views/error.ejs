<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <nav class="hud">
    <a class="rpg-btn is-gold" href="/" style="font-size:11px;padding:6px 12px;">🗺️ ホーム</a>
    <div class="hud-spacer"></div>
  </nav>

  <main class="main" style="text-align:center;">
    <div style="font-size:64px; margin: 40px 0 12px; text-shadow: 4px 4px 0 var(--shadow);">⚠️</div>
    <h1 class="rpg-title" style="font-size: 28px; margin-bottom: 12px;"><%= title %></h1>

    <section class="rpg-window is-open" style="display:inline-block; max-width: 560px; text-align:left;">
      <p style="font-family: var(--font-body); color: var(--ink); line-height: 1.7; margin: 0;">
        <%= message %>
      </p>
    </section>

    <div style="margin-top: 28px;">
      <a href="/" class="rpg-btn is-gold">← ホームに戻る</a>
    </div>
  </main>
</body>
</html>
