<%- include('partials/head', { title: title }) %>
<header class="border-b border-line">
  <div class="mx-auto flex max-w-5xl items-center px-5 py-3 sm:px-8">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
      <span class="grid h-6 w-6 place-items-center rounded-md bg-accent text-[13px] font-bold text-accent-ink">Q</span>
      <span class="text-[15px]">Questara</span>
    </a>
  </div>
</header>

<main class="mx-auto flex max-w-2xl flex-col items-center px-5 py-20 text-center sm:px-8">
  <div class="mb-4 text-5xl" aria-hidden="true">⚠️</div>
  <h1 class="mb-3 text-2xl font-semibold tracking-tight"><%= title %></h1>
  <p class="max-w-md leading-relaxed text-ink-2"><%= message %></p>
  <a href="/" class="btn btn-primary mt-8">← ホームに戻る</a>
</main>
<%- include('partials/foot') %>
