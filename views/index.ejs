<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-gray-900 text-white px-6 py-3 flex items-center justify-between">
    <a href="/" class="text-lg font-bold tracking-tight">📚 資格学習エージェント</a>
    <div class="flex items-center gap-4 text-sm">
      <span class="text-gray-400"><%= userEmail %></span>
      <form method="POST" action="/auth/logout" class="inline">
        <button type="submit" class="text-gray-400 hover:text-white transition">ログアウト</button>
      </form>
    </div>
  </nav>
  <main class="max-w-4xl mx-auto px-4 py-8">

    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold">学習する資格を選んでください</h1>
    </div>

    <nav class="flex gap-4 mb-6 text-sm">
      <a href="/my/certifications" class="text-blue-600 hover:underline">マイ資格</a>
      <a href="/ranking" class="text-blue-600 hover:underline">ランキング</a>
      <a href="/plans" class="text-blue-600 hover:underline">学習計画</a>
    </nav>

    <div class="mb-4 border-b">
      <button onclick="showTab('public')" id="tab-public"
              class="px-4 py-2 border-b-2 border-blue-600 font-semibold text-sm">
        公開資格 (<%= publicCerts.length %>)
      </button>
      <button onclick="showTab('mine')" id="tab-mine"
              class="px-4 py-2 border-b-2 border-transparent text-gray-500 text-sm">
        自分の非公開資格 (<%= myCerts.length %>)
      </button>
    </div>

    <div id="panel-public">
      <% if (publicCerts.length === 0) { %>
        <p class="text-gray-500">公開資格がありません。</p>
      <% } else { %>
        <div class="space-y-3">
          <% for (const cert of publicCerts) { %>
            <a href="/certifications/<%= cert.id %>"
               class="block bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow">
              <h2 class="text-xl font-semibold text-gray-800"><%= cert.name %></h2>
              <p class="text-sm text-gray-500 mt-1">
                <%= cert.domainCount %> ドメイン &nbsp;·&nbsp; <%= cert.questionCount %> 問
                <% if (cert.createdBy !== 'system') { %>
                  &nbsp;·&nbsp; 作成者: <%= cert.creatorName %>
                <% } %>
              </p>
            </a>
          <% } %>
        </div>
      <% } %>
    </div>

    <div id="panel-mine" class="hidden">
      <% if (myCerts.length === 0) { %>
        <p class="text-gray-500">
          非公開資格はありません。
          <a href="/my/certifications/new" class="text-blue-600 hover:underline">新規作成</a>
        </p>
      <% } else { %>
        <div class="space-y-3">
          <% for (const cert of myCerts) { %>
            <a href="/certifications/<%= cert.id %>"
               class="block bg-white rounded-xl border border-gray-200 p-4 hover:shadow-md transition-shadow">
              <h2 class="text-xl font-semibold text-gray-800"><%= cert.name %></h2>
              <p class="text-sm text-gray-500 mt-1">
                <%= cert.domainCount %> ドメイン &nbsp;·&nbsp; <%= cert.questionCount %> 問 &nbsp;·&nbsp; 非公開
              </p>
            </a>
          <% } %>
        </div>
      <% } %>
    </div>

    <script>
      function showTab(key) {
        for (const t of ['public', 'mine']) {
          const btn = document.getElementById('tab-' + t);
          const panel = document.getElementById('panel-' + t);
          if (t === key) {
            btn.classList.add('border-blue-600', 'font-semibold');
            btn.classList.remove('border-transparent', 'text-gray-500');
            panel.classList.remove('hidden');
          } else {
            btn.classList.remove('border-blue-600', 'font-semibold');
            btn.classList.add('border-transparent', 'text-gray-500');
            panel.classList.add('hidden');
          }
        }
      }
    </script>

  </main>
</body>
</html>
