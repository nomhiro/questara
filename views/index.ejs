<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>
  <main class="main">

    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:24px;">
      <h1 class="rpg-title" style="font-size: 24px;">学習する資格を選んでください</h1>
    </div>

    <div style="display:flex; gap:12px; margin-bottom:24px; flex-wrap:wrap;">
      <a href="/my/certifications" class="rpg-btn">マイ資格</a>
      <a href="/ranking" class="rpg-btn">ランキング</a>
      <a href="/plans" class="rpg-btn">学習計画</a>
    </div>

    <div style="display:flex; gap:4px; margin-bottom:16px; border-bottom:2px solid var(--window-lt);">
      <button onclick="showTab('public')" id="tab-public"
              style="padding:8px 16px; background:transparent; border:none; border-bottom:3px solid var(--gold); font-family: var(--font-display); color: var(--ink); cursor:pointer;">
        公開資格 (<%= publicCerts.length %>)
      </button>
      <button onclick="showTab('mine')" id="tab-mine"
              style="padding:8px 16px; background:transparent; border:none; border-bottom:3px solid transparent; font-family: var(--font-display); color:#c0c6e0; cursor:pointer;">
        自分の非公開資格 (<%= myCerts.length %>)
      </button>
    </div>

    <div id="panel-public">
      <% if (publicCerts.length === 0) { %>
        <p style="color:#c0c6e0; font-family: var(--font-body);">公開資格がありません。</p>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <% for (const cert of publicCerts) { %>
            <div class="rpg-window" style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
              <a href="/certifications/<%= cert.id %>" style="display:block; text-decoration:none; flex:1; min-width:0;">
                <h2 class="rpg-title" style="font-size: 16px;">
                  <%= cert.name %>
                  <% if (passedIds.has(cert.id)) { %><span class="pill" style="color: var(--fern); border-color: var(--fern);">🎓 合格</span><% } %>
                </h2>
                <p style="color:#c0c6e0; font-family: var(--font-body); margin-top:4px; font-size: 13px;">
                  <%= cert.domainCount %> ドメイン &nbsp;·&nbsp; <%= cert.questionCount %> 問
                  <% if (cert.createdBy !== 'system') { %>
                    &nbsp;·&nbsp; 作成者: <%= cert.creatorName %>
                  <% } %>
                </p>
              </a>
              <form method="POST" action="/my/certifications/<%= cert.id %>/<%= favoriteIds.has(cert.id) ? 'unfavorite' : 'favorite' %>" style="margin:0; flex-shrink:0;">
                <input type="hidden" name="returnTo" value="/free-mode">
                <button class="rpg-btn" title="お気に入り"><%= favoriteIds.has(cert.id) ? '★' : '☆' %></button>
              </form>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <div id="panel-mine" class="hidden">
      <% if (myCerts.length === 0) { %>
        <p style="color:#c0c6e0; font-family: var(--font-body);">
          非公開資格はありません。
          <a href="/my/certifications/new" style="color: var(--gold);">新規作成</a>
        </p>
      <% } else { %>
        <div style="display:flex; flex-direction:column; gap:12px;">
          <% for (const cert of myCerts) { %>
            <div class="rpg-window" style="display:flex; align-items:center; justify-content:space-between; gap:8px;">
              <a href="/certifications/<%= cert.id %>" style="display:block; text-decoration:none; flex:1; min-width:0;">
                <h2 class="rpg-title" style="font-size: 16px;">
                  <%= cert.name %>
                  <% if (passedIds.has(cert.id)) { %><span class="pill" style="color: var(--fern); border-color: var(--fern);">🎓 合格</span><% } %>
                </h2>
                <p style="color:#c0c6e0; font-family: var(--font-body); margin-top:4px; font-size: 13px;">
                  <%= cert.domainCount %> ドメイン &nbsp;·&nbsp; <%= cert.questionCount %> 問 &nbsp;·&nbsp; 非公開
                </p>
              </a>
              <form method="POST" action="/my/certifications/<%= cert.id %>/<%= favoriteIds.has(cert.id) ? 'unfavorite' : 'favorite' %>" style="margin:0; flex-shrink:0;">
                <input type="hidden" name="returnTo" value="/free-mode">
                <button class="rpg-btn" title="お気に入り"><%= favoriteIds.has(cert.id) ? '★' : '☆' %></button>
              </form>
            </div>
          <% } %>
        </div>
      <% } %>
    </div>

    <script>
      function showTab(key) {
        for (const t of ['public', 'mine']) {
          const btn = document.getElementById('tab-' + t);
          const panel = document.getElementById('panel-' + t);
          if (t === key) {
            btn.style.borderBottomColor = 'var(--gold)';
            btn.style.color = 'var(--ink)';
            panel.classList.remove('hidden');
          } else {
            btn.style.borderBottomColor = 'transparent';
            btn.style.color = '#c0c6e0';
            panel.classList.add('hidden');
          }
        }
      }
    </script>

  </main>
</body>
</html>
