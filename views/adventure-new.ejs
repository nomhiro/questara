<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    html, body { height: 100%; margin: 0; overflow: hidden; }
    body { display: flex; flex-direction: column; min-height: 100vh; }
    body > nav.hud { flex: 0 0 auto; }
    body > form#presetForm { flex: 1 1 auto; min-height: 0; display: flex; }
    body > form#presetForm > .picker-layout {
      flex: 1 1 auto;
      height: auto;
      min-height: 0;
      width: 100%;
    }
    @media (max-width: 960px) {
      html, body { height: auto; overflow: auto; }
      body { display: block; }
      body > form#presetForm { display: block; }
      body > form#presetForm > .picker-layout {
        min-height: calc(100vh - 72px);
      }
    }
  </style>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

  <form method="POST" action="/adventures/preset" id="presetForm">
    <div class="picker-layout">

      <!-- Left: Map -->
      <div class="picker-left">
        <header class="picker-header">
          <h1 class="rpg-title" style="font-size: 22px;">🔮 冒険の地図</h1>
          <p class="sub">
            この地にはいくつもの認定資格が点在。右の <strong style="color: var(--gold);">「道」</strong> を <strong style="color: var(--fern);">複数選ぶ</strong> と、それぞれの路が地図上で光ります。重なる拠点（🏘 AZ-900 など）は自動で 1 回だけ通過。
          </p>
        </header>

        <div class="map-wrap">
          <div class="world-map" id="worldMap">
            <svg class="world-svg" viewBox="0 0 1000 720" preserveAspectRatio="none">
              <% for (const r of routes) { %>
                <% if (r.points.length >= 2) { %>
                  <polyline
                    class="route route-<%= r.id %>"
                    points="<%= r.points.map((p) => `${p.x},${p.y}`).join(' ') %>"
                    stroke="<%= r.color %>"
                    stroke-width="5"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-dasharray="12,8"
                    opacity="0.45"
                    data-preset-id="<%= r.id %>"
                  />
                <% } %>
              <% } %>
            </svg>

            <% for (const n of nodes) { %>
              <div class="world-node <%= n.available ? '' : 'is-locked' %>"
                   data-cert-id="<%= n.certId %>"
                   data-presets="<%= n.presets.join(' ') %>"
                   style="left: <%= (n.position.x/1000)*100 %>%; top: <%= (n.position.y/720)*100 %>%;">
                <div class="sprite"><%= n.position.icon || '🏰' %></div>
                <div class="cert-id"><%= n.certId.toUpperCase() %></div>
                <div class="place"><%= n.position.label %></div>
              </div>
            <% } %>

            <div class="world-legend">
              <div class="row">🗺 道</div>
              <% for (const r of routes) { %>
                <div class="row">
                  <span class="swatch" style="background: <%= r.color %>;"></span>
                  <span><%= r.icon %> <%= r.name %></span>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Selection panel -->
      <aside class="picker-panel">
        <div class="panel-title">🗡 歩む道（複数選択可）</div>

        <div class="preset-list">
          <% for (const p of presets) {
               const color = p.id === 'developer' ? '#ffc425' : p.id === 'infra' ? '#6fb6ff' : p.id === 'ai-engineer' ? '#ce93d8' : '#ffffff';
          %>
            <label class="preset-card" data-preset-id="<%= p.id %>"
                   onmouseenter="onCardHover('<%= p.id %>', true)"
                   onmouseleave="onCardHover('<%= p.id %>', false)">
              <input type="checkbox" name="presetIds" value="<%= p.id %>" hidden
                     onchange="onCardToggle('<%= p.id %>')"
                     <%= p.availableCount === 0 ? 'disabled' : '' %>>
              <div class="head">
                <div style="display:flex;align-items:center;gap:8px;flex:1;min-width:0;">
                  <div class="icon"><%= p.icon %></div>
                  <div style="flex:1;min-width:0;">
                    <div class="name"><%= p.name %></div>
                    <div class="tagline"><%= p.tagline %></div>
                  </div>
                </div>
                <% if (p.officialUrl) { %>
                  <a href="<%= p.officialUrl %>" target="_blank" rel="noopener"
                     onclick="event.stopPropagation();"
                     style="font-family: var(--font-display); font-size: 9px; color: <%= color %>; border: 2px solid <%= color %>; padding: 2px 6px; text-decoration:none; white-space: nowrap;">
                    📖 公式
                  </a>
                <% } %>
              </div>
              <div class="count <%= p.availableCount === 0 ? 'warn' : '' %>">
                挑戦可 <%= p.availableCount %>／<%= p.dungeons.length %>
              </div>
              <div class="go">
                <% if (p.availableCount === 0) { %>
                  <div class="rpg-btn" style="width: 100%; opacity: .45; cursor: not-allowed; pointer-events: none;">⚠ 資格未登録</div>
                <% } else { %>
                  <div class="rpg-btn" style="width: 100%; pointer-events: none;">🗡 この道を選ぶ</div>
                <% } %>
              </div>
            </label>
          <% } %>
        </div>

        <!-- Selection summary + submit -->
        <div class="selection-bar">
          <div class="row primary">
            <span class="label">選択中</span>
            <span class="value"><span id="selectionCount">0</span> 本</span>
          </div>
          <div class="names" id="selectionNames">（道を選ぶとここに表示）</div>
          <div class="row">
            <span class="label">合計拠点</span>
            <span class="value">
              <span id="mergedDungeonCount">0</span>
              <span style="color: #c0c6e0; margin-left:4px;">(挑戦可 <span id="mergedAvailableCount" style="color: var(--fern);">0</span>)</span>
            </span>
          </div>
          <div class="actions">
            <button type="button" class="rpg-btn" onclick="clearAllSelections()">クリア</button>
            <button type="submit" class="rpg-btn is-gold" id="submitBtn" disabled>冒険を始める</button>
          </div>
        </div>

        <div class="extras">
          <div class="rpg-window" style="padding: 10px 12px;">
            <div style="font-family: var(--font-display); color: var(--gold); font-size: 12px; margin-bottom: 4px;">💬 水晶玉に問う</div>
            <textarea id="llmPrompt" rows="2" placeholder="例: バックエンドとAIに強いエンジニアになりたい"
              style="width:100%;background:#000;color:var(--ink);border:2px solid var(--ink);border-radius:0;font-family:var(--font-body);font-size:12px;padding:6px 8px;resize:vertical;"></textarea>
            <div style="display:flex; gap:6px; margin-top:6px;">
              <button type="button" class="rpg-btn is-fern" id="llmAskBtn" style="flex:1; font-size:11px; padding:5px 10px;">🔮 問う</button>
              <button type="button" class="rpg-btn" id="llmCancelBtn" style="flex:0 0 auto; font-size:11px; padding:5px 10px; display:none;">中止</button>
            </div>
            <pre id="llmLog" style="margin-top:6px; color:var(--gold); font-family:var(--font-display); font-size:11px; white-space:pre-wrap; max-height:110px; overflow:auto; display:none; background:#0008; padding:6px 8px;"></pre>
          </div>
          <div>🛠 未登録の資格を追加: <a href="/my/certifications/new">マイ資格 → 新規作成</a></div>
        </div>
      </aside>

    </div>
  </form>

  <script>
    const PRESETS_DATA = <%- JSON.stringify(presets.map((p) => ({
      id: p.id,
      name: p.name,
      dungeons: p.dungeons.map((d) => ({ certId: d.certId, available: d.available })),
    }))) %>;

    function getSelectedPresetIds() {
      return [...document.querySelectorAll('input[name="presetIds"]:checked')].map((el) => el.value);
    }

    function updateHighlights() {
      const selected = new Set(getSelectedPresetIds());
      const hasSelection = selected.size > 0;

      document.querySelectorAll('.world-svg .route').forEach((el) => {
        const id = el.dataset.presetId;
        if (!hasSelection) {
          el.classList.remove('is-highlight', 'is-dimmed');
        } else if (selected.has(id)) {
          el.classList.add('is-highlight');
          el.classList.remove('is-dimmed');
        } else {
          el.classList.remove('is-highlight');
          el.classList.add('is-dimmed');
        }
      });
      document.querySelectorAll('.world-node').forEach((el) => {
        const presets = (el.dataset.presets || '').split(' ').filter(Boolean);
        const inSelected = presets.some((p) => selected.has(p));
        if (!hasSelection) {
          el.classList.remove('is-highlight', 'is-dimmed');
        } else if (inSelected) {
          el.classList.add('is-highlight');
          el.classList.remove('is-dimmed');
        } else {
          el.classList.remove('is-highlight');
          el.classList.add('is-dimmed');
        }
      });
    }

    function updatePresetCardVisuals() {
      const selected = new Set(getSelectedPresetIds());
      document.querySelectorAll('.preset-card').forEach((el) => {
        const id = el.dataset.presetId;
        const isSelected = selected.has(id);
        el.classList.toggle('is-highlight', isSelected);
        const btn = el.querySelector('.go .rpg-btn');
        if (btn && !btn.textContent.includes('未登録')) {
          btn.textContent = isSelected ? '✔ 選択中' : '🗡 この道を選ぶ';
          btn.classList.toggle('is-fern', isSelected);
        }
      });
    }

    function updateSelectionBar() {
      const selectedIds = getSelectedPresetIds();
      document.getElementById('selectionCount').textContent = selectedIds.length;
      const namesEl = document.getElementById('selectionNames');
      if (selectedIds.length === 0) {
        namesEl.textContent = '（道を選ぶとここに表示）';
      } else {
        namesEl.textContent = selectedIds.map((id) => PRESETS_DATA.find((p) => p.id === id)?.name || id).join(' × ');
      }

      const seen = new Set();
      const availableSeen = new Set();
      for (const id of selectedIds) {
        const p = PRESETS_DATA.find((pp) => pp.id === id);
        if (!p) continue;
        for (const d of p.dungeons) {
          if (!seen.has(d.certId)) {
            seen.add(d.certId);
            if (d.available) availableSeen.add(d.certId);
          }
        }
      }
      document.getElementById('mergedDungeonCount').textContent = seen.size;
      document.getElementById('mergedAvailableCount').textContent = availableSeen.size;
      document.getElementById('submitBtn').disabled = availableSeen.size === 0;
    }

    function onCardToggle() {
      updateHighlights();
      updatePresetCardVisuals();
      updateSelectionBar();
    }

    function onCardHover(presetId, isEnter) {
      const selected = getSelectedPresetIds();
      if (selected.length > 0) return;
      if (isEnter) {
        document.querySelectorAll('.world-svg .route').forEach((el) => {
          const match = el.dataset.presetId === presetId;
          el.classList.toggle('is-highlight', match);
          el.classList.toggle('is-dimmed', !match);
        });
        document.querySelectorAll('.world-node').forEach((el) => {
          const presets = (el.dataset.presets || '').split(' ').filter(Boolean);
          const match = presets.includes(presetId);
          el.classList.toggle('is-highlight', match);
          el.classList.toggle('is-dimmed', !match);
        });
      } else {
        document.querySelectorAll('.world-svg .route').forEach((el) => el.classList.remove('is-highlight', 'is-dimmed'));
        document.querySelectorAll('.world-node').forEach((el) => el.classList.remove('is-highlight', 'is-dimmed'));
      }
    }

    function clearAllSelections() {
      document.querySelectorAll('input[name="presetIds"]:checked').forEach((el) => { el.checked = false; });
      updateHighlights();
      updatePresetCardVisuals();
      updateSelectionBar();
    }

    // === 水晶玉 (LLM 冒険生成) ===
    async function askCrystal() {
      const prompt = document.getElementById('llmPrompt').value.trim();
      const log = document.getElementById('llmLog');
      const askBtn = document.getElementById('llmAskBtn');
      const cancelBtn = document.getElementById('llmCancelBtn');
      if (!prompt) {
        log.style.display = 'block';
        log.textContent = '▸ 希望の勇者像を入力してください。';
        return;
      }
      log.style.display = 'block';
      log.textContent = '▸ 水晶玉に問いかけています...';
      askBtn.disabled = true;
      cancelBtn.style.display = '';

      const controller = new AbortController();
      cancelBtn.onclick = () => { controller.abort(); };

      try {
        const res = await fetch('/api/adventures/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userPrompt: prompt }),
          signal: controller.signal,
        });
        if (!res.ok || !res.body) {
          log.textContent += '\n❌ 通信に失敗しました (HTTP ' + res.status + ')';
          return;
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const chunks = buf.split('\n\n');
          buf = chunks.pop();
          for (const chunk of chunks) {
            const evMatch = chunk.match(/^event:\s*(\w+)/m);
            const daMatch = chunk.match(/^data:\s*(.+)$/m);
            if (!evMatch || !daMatch) continue;
            let payload;
            try { payload = JSON.parse(daMatch[1]); } catch { continue; }
            if (evMatch[1] === 'progress') log.textContent += '\n▸ ' + payload.message;
            else if (evMatch[1] === 'done') { log.textContent += '\n✅ 冒険を生成しました。移動中...'; location.href = '/adventures/' + payload.adventureId; return; }
            else if (evMatch[1] === 'error') { log.textContent += '\n❌ ' + payload.error; return; }
          }
        }
      } catch (err) {
        if (err.name === 'AbortError') log.textContent += '\n⚠ 中止しました。';
        else log.textContent += '\n❌ ' + err.message;
      } finally {
        askBtn.disabled = false;
        cancelBtn.style.display = 'none';
      }
    }
    document.getElementById('llmAskBtn')?.addEventListener('click', askCrystal);
    updateSelectionBar();
  </script>
</body>
</html>
