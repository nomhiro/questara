<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-4xl px-5 py-8 sm:px-8">
  <h1 class="mb-6 text-2xl font-semibold tracking-tight">ステータス</h1>

  <% const xpInto = stats.xpIntoLevel || 0;
     const xpFor = stats.xpForLevel || 100;
     const xpPct = Math.min(100, Math.round((xpInto / xpFor) * 100));
     const streak = (stats.streak && stats.streak.current) || 0;
     const longest = (stats.streak && stats.streak.longest) || 0;
     const freeze = !!(stats.streak && stats.streak.freeze);
  %>

  <section class="card flex flex-wrap items-center gap-5">
    <% if (profileUser.avatarUrl) { %>
      <img src="<%= profileUser.avatarUrl %>" alt="avatar" class="h-20 w-20 rounded-full border border-line object-cover">
    <% } else { %>
      <div class="grid h-20 w-20 place-items-center rounded-full bg-surface-3 text-4xl">🧙</div>
    <% } %>
    <div class="min-w-[240px] flex-1">
      <div class="text-xl font-semibold"><%= profileUser.name %></div>
      <div class="mt-1 text-sm text-ink-2">Lv.<span class="nums font-medium text-ink"><%= stats.level || 1 %></span> · 総EXP <span class="nums font-medium text-ink"><%= stats.xp || 0 %></span></div>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-ink-2">
        <span>次のLvまで</span>
        <span class="progress w-48"><i style="width:<%= xpPct %>%"></i></span>
        <span class="nums"><%= xpInto %>/<%= xpFor %></span>
        <span class="text-ink-3">（残り <%= Math.max(0, xpFor - xpInto) %>）</span>
      </div>
      <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm">
        <span>🔥 連続 <span class="nums"><%= streak %></span>日</span>
        <span class="text-ink-2">最長 <span class="nums"><%= longest %></span>日</span>
        <% if (freeze) { %><span class="text-accent">🧚 妖精の加護あり</span><% } %>
      </div>
    </div>
  </section>

  <% if (stats.dailyQuest && stats.dailyQuest.date) { %>
    <section class="card mt-5">
      <h2 class="mb-3 text-base font-semibold tracking-tight">本日のクエスト</h2>
      <% const completed = new Set(stats.dailyQuest.completed || []); %>
      <ul class="flex flex-col gap-2">
        <% for (const q of [
          ['daily-session',   '1セッション完了',          30],
          ['daily-5q',        '今日5問解く',              50],
          ['daily-domain-80', '1ドメインで正答率80%以上',  80],
        ]) { const id = q[0], name = q[1], xp = q[2]; const ok = completed.has(id); %>
          <li class="flex items-center justify-between rounded-lg border-l-2 px-3 py-2 text-sm <%= ok ? 'border-success bg-success-soft opacity-70' : 'border-accent bg-surface-3' %>">
            <span class="<%= ok ? 'line-through' : '' %>"><%= name %></span>
            <span class="nums <%= ok ? 'text-success' : 'text-accent' %>">+<%= xp %> EXP</span>
          </li>
        <% } %>
      </ul>
    </section>
  <% } %>

  <h2 class="mb-3 mt-7 text-base font-semibold tracking-tight">実績 (<span class="nums"><%= unlocked.size %>/<%= achievementsMaster.length %></span>)</h2>
  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
    <% for (const a of achievementsMaster) { const ok = unlocked.has(a.id); %>
      <div class="card flex flex-col items-center gap-1 p-4 text-center <%= ok ? '' : 'opacity-40 grayscale' %>" title="<%= a.description %>">
        <div class="text-3xl"><%= a.icon %></div>
        <div class="text-sm font-medium"><%= a.name %></div>
        <div class="text-xs text-ink-2"><%= a.description %></div>
        <div class="nums mt-1 text-xs <%= ok ? 'text-success' : 'text-ink-3' %>"><%= ok ? '解放済み' : `+${a.xpReward} EXP` %></div>
      </div>
    <% } %>
  </div>

  <% if (passedCerts && passedCerts.length) { %>
    <h2 class="mb-3 mt-7 text-base font-semibold tracking-tight">🎓 合格資格 (<span class="nums"><%= passedCerts.length %></span>)</h2>
    <section class="card">
      <ul class="flex flex-col gap-2 text-sm">
        <% for (const c of passedCerts) { %>
          <li class="flex items-center justify-between rounded-lg border-l-2 border-success bg-success-soft px-3 py-2">
            <span><%= c.name %></span>
            <span class="nums text-ink-2"><%= c.passedAt %></span>
          </li>
        <% } %>
      </ul>
    </section>
  <% } %>
</main>
<%- include('partials/foot') %>
