<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-4xl px-5 py-8 sm:px-8">
  <nav class="mb-4 flex items-center gap-2 text-sm text-ink-3" aria-label="パンくず">
    <a href="/home" class="text-ink-2 hover:text-ink">ホーム</a>
    <span aria-hidden="true">/</span>
    <a href="/certifications/<%= cert.id %>" class="text-ink-2 hover:text-ink"><%= cert.name %></a>
    <span aria-hidden="true">/</span>
    <span class="text-ink"><%= domain.name %></span>
  </nav>

  <div class="mb-7 flex flex-wrap items-start justify-between gap-4">
    <div class="min-w-[260px] flex-1">
      <h1 class="mb-2 text-xl font-semibold tracking-tight"><%= domain.name %></h1>
      <div class="flex flex-wrap gap-2">
        <span class="badge"><span class="nums"><%= domain.questions.length %></span> 問</span>
        <span class="badge">試験ウェイト <span class="nums"><%= domain.weight %></span>%</span>
        <% if (domain.generatedAt) { %>
          <span class="badge badge-success">最終生成: <%= new Date(domain.generatedAt).toLocaleString('ja-JP') %></span>
        <% } else { %>
          <span class="badge badge-accent">未生成 (シード)</span>
        <% } %>
      </div>
    </div>
    <form method="POST" action="/quiz/start" class="m-0">
      <input type="hidden" name="certId" value="<%= cert.id %>">
      <input type="hidden" name="mode" value="domain">
      <input type="hidden" name="domainId" value="<%= domain.id %>">
      <button class="btn btn-primary" type="submit">このドメインで練習</button>
    </form>
  </div>

  <% if (stats.total > 0) { const pass = stats.rate >= 70; %>
    <section class="card mb-7">
      <div class="flex flex-wrap items-center gap-5">
        <div class="nums text-4xl font-semibold <%= pass ? 'text-success' : 'text-danger' %>"><%= stats.rate %>%</div>
        <div>
          <div class="text-sm font-medium">累積正答率</div>
          <div class="text-xs text-ink-2"><span class="nums"><%= stats.correct %> / <%= stats.total %></span> 問正解</div>
        </div>
        <div class="min-w-[180px] flex-1">
          <span class="progress block <%= pass ? 'is-success' : 'is-danger' %>"><i style="width:<%= stats.rate %>%"></i></span>
        </div>
      </div>
    </section>
  <% } %>

  <section class="card mb-9">
    <h2 class="text-base font-semibold tracking-tight">AI による問題追加生成</h2>
    <p class="mt-1.5 text-sm leading-relaxed text-ink-2">
      学習ガイドのテキストを取得し、このドメインに特化した新しい問題を生成します。
      既存の <strong class="font-medium text-ink nums"><%= domain.questions.length %></strong> 問に追加されます（解答履歴は保持されます）。
    </p>
    <div class="mt-4">
      <label for="modelSelect" class="mb-1.5 block text-xs font-medium text-ink-2">生成モデル</label>
      <select id="modelSelect" class="field max-w-xs">
        <option value="openai/gpt-4.1">openai/gpt-4.1</option>
      </select>
    </div>
    <button id="generateBtn" class="btn btn-primary mt-4" onclick="startGeneration('<%= cert.id %>', '<%= domain.id %>')">問題を追加生成する</button>
    <div id="generateProgress" class="mt-4 hidden">
      <div class="flex items-center gap-2 text-sm text-accent">
        <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-accent"></span>
        <span id="progressMsg">処理中...</span>
      </div>
    </div>
    <div id="generateResult" class="mt-3 hidden rounded-lg border px-3 py-2.5 text-sm"></div>
  </section>

  <h2 class="mb-3 text-lg font-semibold tracking-tight">現在の問題一覧 (<span class="nums"><%= domain.questions.length %></span> 問)</h2>
  <div class="grid gap-2.5">
    <% for (let i = 0; i < domain.questions.length; i++) { %>
      <% const q = domain.questions[i]; %>
      <details class="card p-0">
        <summary class="flex cursor-pointer list-none items-baseline gap-2 px-4 py-3 text-sm">
          <span class="nums font-medium text-accent">Q<%= i + 1 %>.</span>
          <span class="text-ink-2"><%= q.question.substring(0, 80) %><%= q.question.length > 80 ? '...' : '' %></span>
        </summary>
        <div class="flex flex-col gap-1.5 px-4 pb-4">
          <% for (const [key, val] of Object.entries(q.options)) { %>
            <% const answerKeys = (Array.isArray(q.correctAnswers) && q.correctAnswers.length > 0) ? q.correctAnswers : [q.correctAnswer]; %>
            <% const isAns = answerKeys.includes(key); %>
            <div class="flex gap-2 rounded-md px-2 py-1 text-sm <%= isAns ? 'bg-success-soft text-success' : 'text-ink-2' %>">
              <span class="font-medium <%= isAns ? 'text-success' : 'text-ink-3' %>"><%= key %>.</span>
              <span><%= val %> <%= isAns ? '✓' : '' %></span>
            </div>
          <% } %>
          <div class="mt-2.5 border-t border-line pt-2.5 text-sm leading-relaxed text-ink-2">
            <span class="font-medium text-ink">解説:</span>
            <%= q.explanation %>
          </div>
        </div>
      </details>
    <% } %>
  </div>
</main>

<script>
  async function loadModels() {
    try {
      const res = await fetch('/api/models');
      if (!res.ok) return; // フォールバック表示（openai/gpt-4.1）のまま
      const data = await res.json();
      const select = document.getElementById('modelSelect');
      select.innerHTML = '';
      const addOption = (group, m) => {
        const opt = document.createElement('option');
        opt.value = m.id;
        opt.textContent = m.id;
        if (m.id === 'openai/gpt-4.1') opt.selected = true;
        group.appendChild(opt);
      };
      const addGroup = (label, models) => {
        if (!models.length) return;
        const g = document.createElement('optgroup');
        g.label = label;
        models.forEach((m) => addOption(g, m));
        select.appendChild(g);
      };
      // custom ティア（gpt-5系・o系・deepseek-r1 等）は有料プラン/プレビュー専用で
      // 無料枠では unavailable_model になるため、別グループに分けて注意喚起する。
      addGroup('標準（GitHub Models 無料枠で利用可）', data.models.filter((m) => m.tier !== 'custom'));
      addGroup('有料プラン/プレビュー（利用不可の場合あり）', data.models.filter((m) => m.tier === 'custom'));
    } catch { /* ネットワークエラー時はフォールバック表示のまま */ }
  }
  loadModels();

  function setResult(el, kind, text) {
    const color = kind === 'success' ? 'var(--success)' : 'var(--danger)';
    const bg = kind === 'success' ? 'var(--success-soft)' : 'var(--danger-soft)';
    el.classList.remove('hidden');
    el.style.borderColor = color;
    el.style.color = color;
    el.style.background = bg;
    el.textContent = text;
  }

  async function startGeneration(certId, domainId) {
    const btn = document.getElementById('generateBtn');
    const progress = document.getElementById('generateProgress');
    const progressMsg = document.getElementById('progressMsg');
    const result = document.getElementById('generateResult');

    btn.disabled = true;
    btn.textContent = '生成中...';
    progress.classList.remove('hidden');
    result.classList.add('hidden');

    try {
      const res = await fetch(`/api/certifications/${certId}/domains/${domainId}/generate`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: document.getElementById('modelSelect').value }),
      });

      if (!res.ok || !res.body) throw new Error('リクエストに失敗しました');

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buffer += decoder.decode(value, { stream: true });

        const lines = buffer.split('\n');
        buffer = lines.pop();

        let eventType = null;
        for (const line of lines) {
          if (line.startsWith('event: ')) {
            eventType = line.slice(7).trim();
          } else if (line.startsWith('data: ')) {
            // JSON パースの失敗（ストリーム途中の不完全な行）だけを無視する。
            let data;
            try {
              data = JSON.parse(line.slice(6));
            } catch (e) {
              continue; // 不完全/不正な data 行はスキップ
            }
            if (eventType === 'progress') {
              progressMsg.textContent = '▸ ' + data.message;
            } else if (eventType === 'done') {
              progress.classList.add('hidden');
              setResult(result, 'success', `✅ ${data.message} ページを再読み込みして確認してください。`);
              btn.textContent = '再読み込み';
              btn.disabled = false;
              btn.onclick = () => location.reload();
              return;
            } else if (eventType === 'error') {
              throw new Error(data.message);
            }
          }
        }
      }
    } catch (err) {
      progress.classList.add('hidden');
      setResult(result, 'error', `❌ エラー: ${err.message}`);
      btn.disabled = false;
      btn.textContent = '問題を追加生成する';
    }
  }
</script>
<%- include('partials/foot') %>
