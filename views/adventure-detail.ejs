<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

  <main class="main">
    <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 16px; flex-wrap: wrap; margin-bottom: 16px;">
      <h1 class="rpg-title" style="font-size: 26px;">⛩ <%= adventure.name %></h1>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="/adventures/new" class="rpg-btn is-fern">🗺 道を選び直す</a>
        <% if (!adventure.isActive) { %>
          <form method="POST" action="/adventures/<%= adventure.id %>/activate" style="margin:0;">
            <button class="rpg-btn is-gold">この冒険に切り替える</button>
          </form>
        <% } else { %>
          <span class="pill" style="color: var(--fern); border-color: var(--fern);">アクティブ</span>
        <% } %>
        <form method="POST" action="/adventures/<%= adventure.id %>/delete" style="margin:0;" onsubmit="return confirm('この冒険を削除しますか？');">
          <button class="rpg-btn">削除</button>
        </form>
      </div>
    </div>

    <% if (adventure.verificationStatus === 'warning-no-citations') { %>
      <div class="rpg-window" style="border-color: var(--crimson); margin-bottom: 16px;">
        <strong style="color: var(--crimson); font-family: var(--font-display);">⚠ 公式確認不足</strong>
        <p style="font-family: var(--font-body); font-size: 12px; margin-top: 4px;">LLM の一般知識のみで生成されました。公式の出典は得られていません。</p>
      </div>
    <% } %>

    <% if (adventure.description) { %>
      <p style="font-family: var(--font-body); color: var(--ink); margin-bottom: 18px;"><%= adventure.description %></p>
    <% } %>

    <section class="rpg-window">
      <h2 class="rpg-title" style="font-size: 16px;">🗡 ダンジョン（攻略順）</h2>
      <ol style="list-style: none; padding: 0; margin: 10px 0 0; display: flex; flex-direction: column; gap: 8px;">
        <% for (const d of adventure.dungeons) {
             const cert = certById[d.certificationId];
             const label = cert ? cert.name : d.certificationId;
             const statusColor = d.status === 'cleared' ? 'var(--fern)' : d.status === 'in-progress' ? 'var(--gold)' : '#888';
             const statusText = d.status === 'cleared' ? '踏破済み' : d.status === 'in-progress' ? '挑戦中' : '未解放';
        %>
          <li style="display: flex; justify-content: space-between; align-items: center; gap: 10px; padding: 10px 12px; background: #0008; border-left: 4px solid <%= statusColor %>;">
            <div style="display:flex; align-items:center; gap: 10px;">
              <span style="font-family: var(--font-display); color: <%= statusColor %>;">#<%= d.order %></span>
              <span style="font-family: var(--font-display); color: var(--ink);"><%= label %></span>
              <span class="pill" style="color: <%= statusColor %>; border-color: <%= statusColor %>; font-size:10px;"><%= statusText %></span>
            </div>
            <div>
              <% if (d.status === 'locked') { %>
                <span style="color:#888; font-family: var(--font-display); font-size:12px;">🔒</span>
              <% } else { %>
                <a href="/certifications/<%= d.certificationId %>" class="rpg-btn is-gold" style="font-size:11px;padding:5px 12px;">入る</a>
              <% } %>
            </div>
          </li>
        <% } %>
      </ol>
    </section>

    <% if (adventure.rationale) { %>
      <section class="rpg-window" style="margin-top: 16px;">
        <h2 class="rpg-title" style="font-size: 16px;">📜 この道を選んだ理由</h2>
        <p style="font-family: var(--font-body); color: var(--ink); line-height: 1.7; margin-top: 8px;"><%= adventure.rationale %></p>
      </section>
    <% } %>

    <% if (adventure.citations && adventure.citations.length) { %>
      <section class="rpg-window" style="margin-top: 16px;">
        <h2 class="rpg-title" style="font-size: 16px;">📖 公式の書（Microsoft Learn）</h2>
        <ul style="list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-direction: column; gap: 6px; font-family: var(--font-body);">
          <% for (const c of adventure.citations) { %>
            <li>📄 <a href="<%= c.url %>" target="_blank" rel="noopener" style="color: var(--gold);"><%= c.title || c.url %></a></li>
          <% } %>
        </ul>
      </section>
    <% } %>
  </main>
</body>
</html>
