<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .home-hero {
      display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .home-hero .info { flex: 1; min-width: 240px; }
    .home-hero .info .adventure-name {
      font-family: var(--font-display); font-size: 22px; color: var(--gold);
      text-shadow: 2px 2px 0 var(--shadow);
    }
    .home-hero .info .adventure-desc {
      font-family: var(--font-body); font-size: 12px; color: #c0c6e0; margin-top: 4px; line-height: 1.6;
    }
    .home-hero .actions { display: flex; gap: 8px; flex-wrap: wrap; }

    .home-map {
      position: relative;
      height: 300px;
      margin: 6px 0 18px;
      background:
        repeating-linear-gradient(0deg, transparent 0 30px, rgba(122,199,79,0.06) 30px 32px),
        repeating-linear-gradient(90deg, transparent 0 30px, rgba(122,199,79,0.06) 30px 32px),
        linear-gradient(180deg, #0b1734 0%, #071025 100%);
      border: 3px solid var(--gold);
      box-shadow: inset 0 0 0 3px #b8891a, 4px 4px 0 var(--shadow);
      overflow: hidden;
    }
    .home-map .path {
      position: absolute; left: 0; right: 0; top: 55%; height: 18px;
      background: repeating-linear-gradient(90deg, #a87a00 0 12px, #7a5a00 12px 14px);
      border-top: 3px solid #d9a733; border-bottom: 3px solid #5a4400;
      transform: skewY(-1.5deg); transform-origin: left;
    }
    .home-node {
      position: absolute; transform: translate(-50%, -50%);
      display: flex; flex-direction: column; align-items: center;
      text-align: center; text-decoration: none; color: var(--ink);
      width: 100px;
      z-index: 2;
    }
    .home-node .sprite {
      width: 56px; height: 56px; display: grid; place-items: center;
      font-size: 32px; line-height: 1;
      background: var(--window); border: 3px solid var(--ink);
      box-shadow: inset 0 0 0 3px var(--window-lt), 3px 3px 0 var(--shadow);
    }
    .home-node .name {
      margin-top: 5px; font-family: var(--font-display); font-size: 10px;
      color: var(--ink); text-shadow: 1px 1px 0 var(--shadow);
      background: #000a; padding: 1px 4px; max-width: 100px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .home-node .rank-chip {
      margin-top: 3px; font-family: var(--font-display); font-size: 9px; padding: 1px 6px;
    }
    .home-node.cleared .sprite { background: #3a6017; border-color: var(--fern); box-shadow: inset 0 0 0 3px #255010, 3px 3px 0 var(--shadow); }
    .home-node.cleared .rank-chip { background: var(--fern); color: var(--shadow); }
    .home-node.current .sprite { background: #b8891a; border-color: var(--gold); box-shadow: inset 0 0 0 3px #6b5012, 3px 3px 0 var(--shadow); animation: node-glow 1.4s steps(2) infinite; }
    .home-node.current .rank-chip { background: var(--gold); color: var(--shadow); }
    .home-node.locked .sprite { background: #2a2a2a; border-color: #555; filter: grayscale(1) brightness(0.7); }
    .home-node.locked .rank-chip { background: #444; color: #888; }
    .home-map .you {
      position: absolute;
      transform: translate(-50%, -50%);
      font-family: var(--font-display); font-size: 20px; color: var(--crimson);
      text-shadow: 2px 2px 0 var(--shadow);
      animation: bob-arrow 0.6s steps(2) infinite;
      pointer-events: none;
      z-index: 3;
    }
    .home-map .hero {
      position: absolute;
      transform: translate(-50%, -50%);
      font-size: 22px; line-height: 1;
      animation: step-hero 0.4s steps(4) infinite;
      pointer-events: none;
      z-index: 3;
    }
    @keyframes bob-arrow { 0%,100% { margin-top: 0; } 50% { margin-top: -6px; } }
    @keyframes step-hero  { 0%,100% { margin-top: 0; } 25%,75% { margin-top: -2px; } }

    .panel-grid {
      display: grid; grid-template-columns: 1.2fr 1fr; gap: 16px;
    }
    @media (max-width: 720px) { .panel-grid { grid-template-columns: 1fr; } }

    .quest-list { list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-direction: column; gap: 6px; font-family: var(--font-display); font-size: 12px; }
    .quest-list li { display: flex; justify-content: space-between; padding: 6px 10px; background: #0008; border-left: 4px solid var(--gold); }
    .quest-list li.done { border-left-color: var(--fern); opacity: .7; text-decoration: line-through; }
    .quest-list .reward { color: var(--gold); }
    .quest-list li.done .reward { color: var(--fern); }

    .ach-list { list-style: none; padding: 0; margin: 8px 0 0; display: flex; flex-direction: column; gap: 6px; }
    .ach-list li { display: flex; gap: 10px; align-items: flex-start; padding: 6px 10px; background: #0008; }
    .ach-list .icon { font-size: 22px; line-height: 1; }
    .ach-list .name { font-family: var(--font-display); color: var(--gold); font-size: 12px; }
    .ach-list .desc { font-family: var(--font-body); font-size: 11px; color: var(--ink); opacity: .85; }
    .ach-list .empty { font-family: var(--font-body); color: #888; font-size: 12px; padding: 8px 10px; background: #0008; text-align: center; }
  </style>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

  <main class="main" style="max-width: 1080px;">

    <!-- 冒険ヘッダー -->
    <section class="rpg-window home-hero">
      <div class="info">
        <div class="adventure-name">⛩ <%= adventure.name %></div>
        <% if (adventure.description) { %>
          <div class="adventure-desc"><%= adventure.description %></div>
        <% } %>
        <% if (adventure.verificationStatus === 'warning-no-citations') { %>
          <div style="margin-top: 6px;">
            <span class="pill" style="color: var(--crimson); border-color: var(--crimson); font-size: 10px;">⚠ 公式確認不足</span>
          </div>
        <% } else if (adventure.citations && adventure.citations.length) { %>
          <div style="margin-top: 6px;">
            <span class="pill" style="color: var(--fern); border-color: var(--fern); font-size: 10px;">📖 公式確認済み（<%= adventure.citations.length %>件）</span>
          </div>
        <% } %>
      </div>
      <div class="actions">
        <a href="/adventures/<%= adventure.id %>" class="rpg-btn">📖 冒険の詳細</a>
        <a href="/adventures/new" class="rpg-btn is-fern">🗺 道を選び直す</a>
        <a href="/free-mode" class="rpg-btn">⚔️ 自由モード</a>
      </div>
    </section>

    <!-- 冒険マップ -->
    <div class="home-map">
      <div class="path"></div>

      <% const N = adventure.dungeons.length; %>
      <% for (let i = 0; i < N; i++) {
           const d = adventure.dungeons[i];
           const cert = certById[d.certificationId];
           const left = N > 1 ? 6 + (88 / (N - 1)) * i : 50;
           const top = 46 + (i % 2) * 14;
           const cls = d.status === 'cleared' ? 'cleared' : d.status === 'in-progress' ? 'current' : 'locked';
           const sprite = d.status === 'cleared' ? '🏰' : d.status === 'in-progress' ? '🗼' : '🔒';
           const rankLabel = d.status === 'cleared' ? '踏破' : d.status === 'in-progress' ? '挑戦中' : '未解放';

           // ドメイン別マスタリーランクの要約
           let domainRanks = [];
           if (cert) {
             domainRanks = cert.domains.map((dm) => masteryRanks[cert.id + ':' + dm.id]?.rank || '-');
           }
           const rankOverview = domainRanks.length ? domainRanks.join(' ') : '';
      %>
        <a class="home-node <%= cls %>"
           href="<%= d.status === 'locked' ? '#' : '/certifications/' + d.certificationId %>"
           style="left: <%= left %>%; top: <%= top %>%;"
           title="<%= cert ? cert.name : d.certificationId %> <%= rankOverview ? ' / ' + rankOverview : '' %>">
          <div class="sprite"><%= sprite %></div>
          <div class="name"><%= cert ? cert.name : d.certificationId.toUpperCase() %></div>
          <div class="rank-chip"><%= rankLabel %></div>
        </a>
        <% if (d.status === 'in-progress') { %>
          <div class="you" style="left: <%= left %>%; top: calc(<%= top %>% - 52px);">▼</div>
          <div class="hero" style="left: <%= left %>%; top: calc(<%= top %>% - 72px);">🧙</div>
        <% } %>
      <% } %>
    </div>

    <!-- パネル：本日のクエスト + 最新の報い -->
    <div class="panel-grid">
      <section class="rpg-window">
        <div class="rpg-title" style="font-size: 14px;">📜 本日のクエスト</div>
        <% if (dailyQuest && dailyQuest.date) {
             const completedSet = new Set(dailyQuest.completed || []); %>
          <ul class="quest-list">
            <% for (const q of [
                 ['daily-session',   '1セッション完了',        30],
                 ['daily-5q',        '今日5問解く',            50],
                 ['daily-domain-80', '1ドメインで正答率80%以上', 80],
               ]) { const id=q[0], name=q[1], xp=q[2]; const ok = completedSet.has(id); %>
              <li class="<%= ok ? 'done' : '' %>">
                <span><%= name %></span>
                <span class="reward">+<%= xp %> EXP</span>
              </li>
            <% } %>
          </ul>
        <% } else { %>
          <div style="font-family: var(--font-body); font-size: 12px; color: #c0c6e0; margin-top: 6px;">
            まずは 1 セッション完了して今日のクエストを開始しましょう。
          </div>
        <% } %>
      </section>

      <section class="rpg-window">
        <div class="rpg-title" style="font-size: 14px;">🏅 最新の報い</div>
        <% if (recentAchievements && recentAchievements.length) { %>
          <ul class="ach-list">
            <% for (const a of recentAchievements) { %>
              <li>
                <div class="icon"><%= a.icon %></div>
                <div>
                  <div class="name"><%= a.name %></div>
                  <div class="desc"><%= a.description %></div>
                </div>
              </li>
            <% } %>
          </ul>
          <div style="margin-top: 8px; text-align: right;">
            <a href="/my/profile" style="font-family: var(--font-display); font-size: 11px; color: var(--gold);">すべての実績 →</a>
          </div>
        <% } else { %>
          <div class="ach-list"><div class="empty">まだ報いはありません。セッションを完走して最初の報いを得よう。</div></div>
        <% } %>
      </section>
    </div>
  </main>
</body>
</html>
