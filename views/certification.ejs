<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-4xl px-5 py-8 sm:px-8">
  <div class="mb-5">
    <h1 class="text-2xl font-semibold tracking-tight"><%= cert.name %></h1>
    <div class="mt-2 flex flex-wrap gap-2">
      <span class="badge"><span class="nums"><%= totalQuestions %></span> 問</span>
      <span class="badge"><span class="nums"><%= domains.length %></span> ドメイン</span>
    </div>
  </div>

  <div class="mb-6 flex flex-wrap gap-2">
    <form method="POST" action="/my/certifications/<%= cert.id %>/<%= isFavorite ? 'unfavorite' : 'favorite' %>" class="m-0">
      <input type="hidden" name="returnTo" value="/certifications/<%= cert.id %>">
      <button class="btn btn-subtle btn-sm"><%= isFavorite ? '★ お気に入り解除' : '☆ お気に入り登録' %></button>
    </form>
    <form method="POST" action="/my/certifications/<%= cert.id %>/<%= isPassed ? 'unpass' : 'pass' %>" class="m-0">
      <input type="hidden" name="returnTo" value="/certifications/<%= cert.id %>">
      <button class="btn btn-sm <%= isPassed ? 'btn-primary' : 'btn-subtle' %>"><%= isPassed ? '🎓 合格を取り消す' : '🎓 合格した' %></button>
    </form>
  </div>

  <div class="mb-8 flex flex-wrap gap-2">
    <form method="POST" action="/quiz/start" class="m-0">
      <input type="hidden" name="certId" value="<%= cert.id %>">
      <input type="hidden" name="mode" value="all">
      <button class="btn btn-primary">全問クイズを開始</button>
    </form>
    <% if (wrongCount > 0) { %>
      <form method="POST" action="/quiz/start" class="m-0">
        <input type="hidden" name="certId" value="<%= cert.id %>">
        <input type="hidden" name="mode" value="wrong-only">
        <button class="btn btn-subtle">間違えた問題のみ（<span class="nums"><%= wrongCount %></span>問）</button>
      </form>
    <% } %>
  </div>

  <h2 class="mb-3 text-lg font-semibold tracking-tight">ドメイン別進捗</h2>
  <div class="grid gap-3">
    <% for (const domain of domains) {
         const mr = masteryRanks[cert.id + ':' + domain.id] || { rank: '未挑戦' };
         const has = domain.stats.total > 0;
         const pass = has && domain.stats.rate >= 70;
    %>
      <div class="card">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div class="min-w-[200px] flex-1">
            <div class="font-medium"><%= domain.name %></div>
            <div class="mt-1 text-xs text-ink-2">
              <span class="nums"><%= domain.questionCount %></span> 問 · 試験ウェイト <span class="nums"><%= domain.weight %></span>%
              <% if (domain.generatedAt) { %> · 最終生成: <%= new Date(domain.generatedAt).toLocaleDateString('ja-JP') %><% } %>
            </div>
          </div>
          <div class="text-right">
            <span class="rank-badge rank-<%= mr.rank === '未挑戦' ? 'D' : mr.rank %><%= mr.rank === '未挑戦' ? ' opacity-50' : '' %>"><%= mr.rank %></span>
            <% if (has) { %>
              <div class="nums mt-1.5 text-lg font-semibold <%= pass ? 'text-success' : 'text-danger' %>"><%= domain.stats.rate %>%</div>
              <div class="text-xs text-ink-3"><span class="nums"><%= domain.stats.correct %>/<%= domain.stats.total %></span> 正解</div>
            <% } else { %>
              <div class="mt-1.5 text-xs text-ink-3">未挑戦</div>
            <% } %>
          </div>
        </div>

        <% if (has) { %>
          <span class="progress mt-3 block <%= pass ? 'is-success' : 'is-danger' %>"><i style="width:<%= domain.stats.rate %>%"></i></span>
        <% } %>

        <div class="mt-3 flex flex-wrap gap-2">
          <form method="POST" action="/quiz/start" class="m-0">
            <input type="hidden" name="certId" value="<%= cert.id %>">
            <input type="hidden" name="mode" value="domain">
            <input type="hidden" name="domainId" value="<%= domain.id %>">
            <button class="btn btn-subtle btn-sm">このドメインで挑戦</button>
          </form>
          <a href="/certifications/<%= cert.id %>/domains/<%= domain.id %>" class="btn btn-ghost btn-sm">問題を管理・生成</a>
        </div>
      </div>
    <% } %>
  </div>
</main>
<%- include('partials/foot') %>
