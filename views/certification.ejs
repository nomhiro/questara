<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <% const s = hudStats || {}; const streak = (s.streak && s.streak.current) || 0;
     const lv = s.level || 1;
     const xpInto = s.xpIntoLevel || 0; const xpFor = s.xpForLevel || 100;
     const xpPct = Math.min(100, Math.round((xpInto / xpFor) * 100));
  %>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

  <main class="main">
    <h1 class="rpg-title" style="font-size: 26px;">🏰 <%= cert.name %></h1>
    <p style="font-family: var(--font-display); color: var(--ink); margin: 6px 0 22px; opacity: .9;">
      <span class="pill"><%= totalQuestions %> 問</span>
      <span class="pill"><%= domains.length %> ドメイン</span>
    </p>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin: 0 0 22px;">
      <form method="POST" action="/my/certifications/<%= cert.id %>/<%= isFavorite ? 'unfavorite' : 'favorite' %>" style="margin:0;">
        <input type="hidden" name="returnTo" value="/certifications/<%= cert.id %>">
        <button class="rpg-btn"><%= isFavorite ? '★ お気に入り解除' : '☆ お気に入り登録' %></button>
      </form>
      <form method="POST" action="/my/certifications/<%= cert.id %>/<%= isPassed ? 'unpass' : 'pass' %>" style="margin:0;">
        <input type="hidden" name="returnTo" value="/certifications/<%= cert.id %>">
        <button class="rpg-btn <%= isPassed ? 'is-fern' : '' %>"><%= isPassed ? '🎓 合格を取り消す' : '🎓 合格した' %></button>
      </form>
    </div>

    <!-- アクションボタン -->
    <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px;">
      <form method="POST" action="/quiz/start" style="margin:0;">
        <input type="hidden" name="certId" value="<%= cert.id %>">
        <input type="hidden" name="mode" value="all">
        <button class="rpg-btn is-gold">🎯 全問クイズを開始</button>
      </form>
      <% if (wrongCount > 0) { %>
        <form method="POST" action="/quiz/start" style="margin:0;">
          <input type="hidden" name="certId" value="<%= cert.id %>">
          <input type="hidden" name="mode" value="wrong-only">
          <button class="rpg-btn">❌ 間違えた問題のみ（<%= wrongCount %>問）</button>
        </form>
      <% } %>
    </div>

    <h2 class="rpg-title" style="font-size: 18px; margin-bottom: 12px;">📊 ドメイン別進捗</h2>
    <div style="display: flex; flex-direction: column; gap: 12px;">
      <% for (const domain of domains) {
           const mr = masteryRanks[cert.id + ':' + domain.id] || { rank: '未挑戦' };
           const rateColor = domain.stats.total > 0 ? (domain.stats.rate >= 70 ? 'var(--fern)' : 'var(--crimson)') : 'var(--ink)';
      %>
        <div class="rpg-window">
          <div style="display: flex; justify-content: space-between; align-items: center; gap: 12px; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 200px;">
              <div style="font-family: var(--font-display); color: var(--ink); font-size: 15px;"><%= domain.name %></div>
              <div style="font-family: var(--font-body); font-size: 12px; color: #c0c6e0; margin-top: 4px;">
                <%= domain.questionCount %> 問 &nbsp;·&nbsp; 試験ウェイト <%= domain.weight %>%
                <% if (domain.generatedAt) { %>
                  &nbsp;·&nbsp; 最終生成: <%= new Date(domain.generatedAt).toLocaleDateString('ja-JP') %>
                <% } %>
              </div>
            </div>
            <div style="text-align: right;">
              <span class="rank-badge rank-<%= mr.rank === '未挑戦' ? 'D' : mr.rank %>" style="<%= mr.rank === '未挑戦' ? 'opacity:.45;' : '' %>">
                <%= mr.rank %>
              </span>
              <% if (domain.stats.total > 0) { %>
                <div style="font-family: var(--font-display); color: <%= rateColor %>; font-size: 18px; margin-top: 6px; text-shadow: 2px 2px 0 var(--shadow);">
                  <%= domain.stats.rate %>%
                </div>
                <div style="font-family: var(--font-body); font-size: 11px; color: #c0c6e0;">
                  <%= domain.stats.correct %>/<%= domain.stats.total %> 正解
                </div>
              <% } else { %>
                <div style="font-family: var(--font-display); color: #888; font-size: 12px; margin-top: 6px;">未挑戦</div>
              <% } %>
            </div>
          </div>

          <% if (domain.stats.total > 0) { %>
            <div style="height: 8px; background: #000; border: 2px solid var(--ink); margin: 12px 0 10px;">
              <div style="height: 100%; background: repeating-linear-gradient(90deg, <%= domain.stats.rate >= 70 ? 'var(--fern)' : 'var(--crimson)' %> 0 6px, #000a 6px 8px); width: <%= domain.stats.rate %>%;"></div>
            </div>
          <% } %>

          <div style="display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px;">
            <form method="POST" action="/quiz/start" style="margin:0;">
              <input type="hidden" name="certId" value="<%= cert.id %>">
              <input type="hidden" name="mode" value="domain">
              <input type="hidden" name="domainId" value="<%= domain.id %>">
              <button class="rpg-btn" style="font-size: 10px; padding: 5px 12px;">このドメインで挑戦</button>
            </form>
            <a href="/certifications/<%= cert.id %>/domains/<%= domain.id %>" class="rpg-btn is-gold" style="font-size: 10px; padding: 5px 12px;">問題を管理・生成</a>
          </div>
        </div>
      <% } %>
    </div>
  </main>
</body>
</html>
