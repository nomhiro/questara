<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>
  <main class="main">
    <h1 class="rpg-title" style="font-size: 24px; margin-bottom: 24px;">🏆 ランキング</h1>

    <div class="rpg-window" style="margin-bottom: 24px;">
      <form method="GET" style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
        <select name="period" style="background:#000; color: var(--ink); border:2px solid var(--ink); padding:6px 10px; font-family: var(--font-body); border-radius:0;">
          <option value="weekly" <%= period === 'weekly' ? 'selected' : '' %>>週次</option>
          <option value="monthly" <%= period === 'monthly' ? 'selected' : '' %>>月次</option>
        </select>
        <select name="certId" style="background:#000; color: var(--ink); border:2px solid var(--ink); padding:6px 10px; font-family: var(--font-body); border-radius:0;">
          <option value="">全資格</option>
          <% for (const c of allCerts) { %>
            <option value="<%= c.id %>" <%= c.id === certId ? 'selected' : '' %>><%= c.name %></option>
          <% } %>
        </select>
        <button class="rpg-btn is-gold">表示</button>
      </form>
    </div>

    <% if (ranking.length === 0) { %>
      <div class="rpg-window" style="text-align:center;">
        <p style="color:#c0c6e0; font-family: var(--font-body);">まだランキングを表示できるデータがありません（最低10問の回答が必要）。</p>
      </div>
    <% } else { %>
      <div class="rpg-window">
        <table style="width:100%; border-collapse: collapse; color: var(--ink); font-family: var(--font-body);">
          <thead>
            <tr>
              <th style="padding:8px 12px; text-align:left; font-family: var(--font-display); color: var(--gold);">順位</th>
              <th style="padding:8px 12px; text-align:left; font-family: var(--font-display); color: var(--gold);">ユーザー</th>
              <th style="padding:8px 12px; text-align:left; font-family: var(--font-display); color: var(--gold);">資格</th>
              <th style="padding:8px 12px; text-align:right; font-family: var(--font-display); color: var(--gold);">正答率</th>
              <th style="padding:8px 12px; text-align:right; font-family: var(--font-display); color: var(--gold);">回答数</th>
            </tr>
          </thead>
          <tbody>
            <% ranking.forEach((r, i) => { %>
              <tr style="border-top: 2px solid var(--window-lt);">
                <td style="padding:8px 12px; font-weight:bold;"><%= i + 1 %></td>
                <td style="padding:8px 12px;"><%= r.user && (r.user.displayName || r.user.username) || 'unknown' %></td>
                <td style="padding:8px 12px; color:#c0c6e0;"><%= r.certificationId %></td>
                <td style="padding:8px 12px; text-align:right; font-weight:bold; color: <%= r.rate >= 70 ? 'var(--fern)' : 'var(--crimson)' %>;">
                  <%= r.rate %>%
                </td>
                <td style="padding:8px 12px; text-align:right; color:#c0c6e0;"><%= r.correct %>/<%= r.total %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>
</body>
</html>
