<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-4xl px-5 py-8 sm:px-8">
  <h1 class="mb-6 text-2xl font-semibold tracking-tight">ランキング</h1>

  <div class="card mb-6">
    <form method="GET" class="flex flex-wrap items-center gap-3">
      <select name="period" class="field w-auto">
        <option value="weekly" <%= period === 'weekly' ? 'selected' : '' %>>週次</option>
        <option value="monthly" <%= period === 'monthly' ? 'selected' : '' %>>月次</option>
      </select>
      <select name="certId" class="field w-auto">
        <option value="">全資格</option>
        <% for (const c of allCerts) { %>
          <option value="<%= c.id %>" <%= c.id === certId ? 'selected' : '' %>><%= c.name %></option>
        <% } %>
      </select>
      <button class="btn btn-primary btn-sm">表示</button>
    </form>
  </div>

  <% if (ranking.length === 0) { %>
    <div class="card text-center text-ink-2">
      <p>まだランキングを表示できるデータがありません（最低10問の回答が必要）。</p>
    </div>
  <% } else { %>
    <div class="card overflow-x-auto p-0">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-line text-left text-xs uppercase tracking-wide text-ink-3">
            <th class="px-4 py-3 font-medium">順位</th>
            <th class="px-4 py-3 font-medium">ユーザー</th>
            <th class="px-4 py-3 font-medium">資格</th>
            <th class="px-4 py-3 text-right font-medium">正答率</th>
            <th class="px-4 py-3 text-right font-medium">回答数</th>
          </tr>
        </thead>
        <tbody>
          <% ranking.forEach((r, i) => { %>
            <tr class="border-b border-line last:border-0">
              <td class="nums px-4 py-3 font-semibold"><%= i + 1 %></td>
              <td class="px-4 py-3"><%= r.user && (r.user.displayName || r.user.username) || 'unknown' %></td>
              <td class="px-4 py-3 text-ink-2"><%= r.certificationId %></td>
              <td class="nums px-4 py-3 text-right font-semibold <%= r.rate >= 70 ? 'text-success' : 'text-danger' %>"><%= r.rate %>%</td>
              <td class="nums px-4 py-3 text-right text-ink-2"><%= r.correct %>/<%= r.total %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</main>
<%- include('partials/foot') %>
