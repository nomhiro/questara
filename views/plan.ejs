<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DotGothic16&family=M+PLUS+1+Code:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
  <%- include('partials/hud', { userEmail: typeof userEmail !== 'undefined' ? userEmail : null, heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>
  <main class="main">
    <h1 class="rpg-title" style="font-size: 24px; margin-bottom: 24px;">📅 学習計画</h1>

    <div class="rpg-window" style="margin-bottom: 24px;">
      <h2 class="rpg-title" style="font-size: 16px; margin-bottom: 12px;">新しい計画を作成</h2>
      <form method="POST" action="/plans" style="display:flex; gap:8px; align-items:end; flex-wrap:wrap;">
        <div>
          <label style="display:block; font-size:12px; color:#c0c6e0; font-family: var(--font-body); margin-bottom:4px;">資格</label>
          <select name="certificationId" required style="background:#000; color: var(--ink); border:2px solid var(--ink); padding:6px 10px; font-family: var(--font-body); border-radius:0;">
            <% if (allCerts.length === 0) { %>
              <option value="">（利用可能な資格がありません）</option>
            <% } %>
            <% for (const c of allCerts) { %>
              <option value="<%= c.id %>"><%= c.name %></option>
            <% } %>
          </select>
        </div>
        <div>
          <label style="display:block; font-size:12px; color:#c0c6e0; font-family: var(--font-body); margin-bottom:4px;">試験予定日</label>
          <input name="examDate" type="date" required style="background:#000; color: var(--ink); border:2px solid var(--ink); padding:6px 10px; font-family: var(--font-body); border-radius:0;">
        </div>
        <button class="rpg-btn is-gold">作成</button>
      </form>
    </div>

    <% if (plans.length === 0) { %>
      <div class="rpg-window" style="text-align:center;">
        <p style="color:#c0c6e0; font-family: var(--font-body);">学習計画がまだありません。</p>
      </div>
    <% } else { %>
      <% for (const p of plans) { %>
        <div class="rpg-window" style="margin-bottom: 16px;">
          <div style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:12px;">
            <div>
              <h2 class="rpg-title" style="font-size: 18px;"><%= p.cert && p.cert.name || p.certificationId %></h2>
              <p style="color:#c0c6e0; font-family: var(--font-body); margin-top:4px; font-size: 12px;">
                試験予定日: <%= p.examDate %> &nbsp;·&nbsp; 全 <%= p.schedule.length %> 週
              </p>
            </div>
            <form method="POST" action="/plans/<%= p.certificationId %>/delete" style="margin:0;"
                  onsubmit="return confirm('削除しますか？');">
              <button class="rpg-btn">削除</button>
            </form>
          </div>
          <% if (p.currentWeek) { %>
            <div style="background: var(--window); border:2px solid var(--gold); padding:8px 12px; margin-bottom:12px;">
              <p style="font-family: var(--font-body); color: var(--ink); font-size:14px;">
                <strong style="color: var(--gold); font-family: var(--font-display);">今週のタスク (Week <%= p.currentWeek.week %>)</strong>:
                <%= p.currentWeek.domains.join(', ') %> を <%= p.currentWeek.targetQuestions %> 問
              </p>
            </div>
          <% } %>
          <details style="font-family: var(--font-body); font-size: 14px;">
            <summary style="cursor:pointer; color:#c0c6e0;">全週スケジュール</summary>
            <ul style="margin-top:8px; display:flex; flex-direction:column; gap:4px; color:#c0c6e0; font-family: var(--font-body);">
              <% for (const s of p.schedule) { %>
                <li>Week <%= s.week %>: <%= s.domains.join(', ') %> (<%= s.targetQuestions %> 問)</li>
              <% } %>
            </ul>
          </details>
        </div>
      <% } %>
    <% } %>
  </main>
</body>
</html>
