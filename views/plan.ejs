<%- include('partials/head', { title: title }) %>
<%- include('partials/hud', { heroHud: typeof heroHud !== 'undefined' ? heroHud : null, combo: null }) %>

<main class="mx-auto max-w-4xl px-5 py-8 sm:px-8">
  <h1 class="mb-6 text-2xl font-semibold tracking-tight">学習計画</h1>

  <div class="card mb-6">
    <h2 class="mb-3 text-base font-semibold tracking-tight">新しい計画を作成</h2>
    <form method="POST" action="/plans" class="flex flex-wrap items-end gap-3">
      <div>
        <label class="mb-1 block text-xs text-ink-2">資格</label>
        <select name="certificationId" required class="field w-auto">
          <% if (allCerts.length === 0) { %><option value="">（利用可能な資格がありません）</option><% } %>
          <% for (const c of allCerts) { %><option value="<%= c.id %>"><%= c.name %></option><% } %>
        </select>
      </div>
      <div>
        <label class="mb-1 block text-xs text-ink-2">試験予定日</label>
        <input name="examDate" type="date" required class="field w-auto">
      </div>
      <button class="btn btn-primary">作成</button>
    </form>
  </div>

  <% if (plans.length === 0) { %>
    <div class="card text-center text-ink-2"><p>学習計画がまだありません。</p></div>
  <% } else { %>
    <div class="grid gap-4">
      <% for (const p of plans) { %>
        <div class="card">
          <div class="mb-3 flex items-start justify-between gap-3">
            <div>
              <h2 class="font-semibold"><%= p.cert && p.cert.name || p.certificationId %></h2>
              <p class="mt-1 text-xs text-ink-2">試験予定日: <span class="nums"><%= p.examDate %></span> · 全 <span class="nums"><%= p.schedule.length %></span> 週</p>
            </div>
            <form method="POST" action="/plans/<%= p.certificationId %>/delete" class="m-0" onsubmit="return confirm('削除しますか？');">
              <button class="btn btn-ghost btn-sm text-danger">削除</button>
            </form>
          </div>
          <% if (p.currentWeek) { %>
            <div class="mb-3 rounded-lg border border-accent/40 bg-accent-soft px-3 py-2.5 text-sm">
              <strong class="font-medium text-accent">今週のタスク (Week <%= p.currentWeek.week %>)</strong>:
              <%= p.currentWeek.domains.join(', ') %> を <span class="nums"><%= p.currentWeek.targetQuestions %></span> 問
            </div>
          <% } %>
          <details class="text-sm">
            <summary class="cursor-pointer text-ink-2">全週スケジュール</summary>
            <ul class="mt-2 flex flex-col gap-1 text-ink-2">
              <% for (const s of p.schedule) { %>
                <li>Week <%= s.week %>: <%= s.domains.join(', ') %> (<span class="nums"><%= s.targetQuestions %></span> 問)</li>
              <% } %>
            </ul>
          </details>
        </div>
      <% } %>
    </div>
  <% } %>
</main>
<%- include('partials/foot') %>
