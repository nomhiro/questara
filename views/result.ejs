<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <nav class="bg-gray-900 text-white px-6 py-3 flex items-center justify-between text-sm">
    <div class="flex items-center gap-2">
      <a href="/" class="font-bold">📚</a>
      <span class="text-gray-400">/</span>
      <% if (cert) { %>
        <a href="/certifications/<%= certId %>" class="text-gray-300 hover:text-white"><%= cert.name %></a>
      <% } %>
      <span class="text-gray-400">/</span>
      <span class="text-gray-200">結果</span>
    </div>
    <form method="POST" action="/auth/logout" class="inline">
      <button type="submit" class="text-gray-400 hover:text-white transition">ログアウト</button>
    </form>
  </nav>
  <main class="max-w-3xl mx-auto px-4 py-8">

    <h1 class="text-2xl font-bold mb-2">セッション結果</h1>

    <!-- 全体スコア -->
    <div class="bg-white rounded-2xl border border-gray-200 p-8 mb-8 text-center shadow-sm">
      <div class="text-6xl font-bold mb-2 <%= overallRate >= 70 ? 'text-green-600' : 'text-red-500' %>">
        <%= overallRate %>%
      </div>
      <p class="text-gray-500"><%= correct %> / <%= total %> 問正解</p>
      <p class="mt-2 text-sm font-medium <%= overallRate >= 70 ? 'text-green-600' : 'text-amber-600' %>">
        <% if (overallRate >= 90) { %>🎉 素晴らしい！合格ラインを大きく上回っています
        <% } else if (overallRate >= 70) { %>✅ 合格ライン (70%) を超えています
        <% } else { %>📖 もう少し学習が必要です (合格ライン: 70%)
        <% } %>
      </p>
    </div>

    <!-- ドメイン別スコア -->
    <% if (domainsWithScores.length > 0) { %>
      <h2 class="font-bold text-lg mb-4">ドメイン別スコア</h2>
      <div class="space-y-3 mb-8">
        <% for (const d of domainsWithScores) { %>
          <div class="bg-white border border-gray-200 rounded-xl p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium text-gray-700 flex-1 pr-4"><%= d.name %></span>
              <span class="font-bold text-sm flex-shrink-0 <%= d.score.rate >= 70 ? 'text-green-600' : 'text-red-500' %>">
                <%= d.score.rate %>%
                <span class="text-xs font-normal text-gray-400 ml-1">(<%= d.score.correct %>/<%= d.score.total %>)</span>
              </span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-2">
              <div class="h-2 rounded-full <%= d.score.rate >= 70 ? 'bg-green-500' : 'bg-red-400' %>"
                   style="width: <%= d.score.rate %>%"></div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- 弱点ドメイン -->
    <% if (weakDomains.length > 0) { %>
      <div class="bg-red-50 border border-red-200 rounded-xl p-5 mb-8">
        <h2 class="font-semibold text-red-700 mb-3">📌 強化が必要なドメイン</h2>
        <div class="space-y-2">
          <% for (const d of weakDomains) { %>
            <div class="flex items-center justify-between">
              <span class="text-sm text-red-700"><%= d.name %></span>
              <div class="flex gap-2">
                <form method="POST" action="/quiz/start">
                  <input type="hidden" name="certId" value="<%= certId %>">
                  <input type="hidden" name="mode" value="domain">
                  <input type="hidden" name="domainId" value="<%= d.id %>">
                  <button class="text-xs bg-red-100 hover:bg-red-200 text-red-700 px-3 py-1.5 rounded-lg">
                    練習する
                  </button>
                </form>
                <a href="/certifications/<%= certId %>/domains/<%= d.id %>"
                   class="text-xs bg-white hover:bg-gray-50 text-gray-600 px-3 py-1.5 rounded-lg border border-gray-200">
                  問題を再生成
                </a>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- アクション -->
    <div class="flex flex-wrap gap-3">
      <% if (cert) { %>
        <form method="POST" action="/quiz/start">
          <input type="hidden" name="certId" value="<%= certId %>">
          <input type="hidden" name="mode" value="all">
          <button class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-5 py-2 rounded-lg text-sm">
            🔄 もう一度全問
          </button>
        </form>
        <a href="/quiz/<%= session.id %>/review?certId=<%= certId %>"
           class="bg-white hover:bg-gray-50 border border-gray-200 text-gray-700 font-semibold px-5 py-2 rounded-lg text-sm inline-block">
          ❌ 間違えた問題を確認
        </a>
        <a href="/certifications/<%= certId %>"
           class="bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold px-5 py-2 rounded-lg text-sm inline-block">
          ← 資格ページへ
        </a>
      <% } %>
    </div>

  </main>
</body>
</html>
