{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "npm run lint",
            "statusMessage": "git push 前の npm run lint を実行中...",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
